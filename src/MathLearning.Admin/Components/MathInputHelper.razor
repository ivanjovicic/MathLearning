@using MathLearning.Admin.Models
@using MudBlazor
@implements IAsyncDisposable
@inject IJSRuntime Js

<div class="math-input-helper">
    <div class="math-helper-header">
        <MudIcon Icon="@Icons.Material.Filled.Functions" Size="Size.Small" Class="mr-1" />
        <MudText Typo="Typo.caption" Style="font-weight:600">LaTeX brzi unos</MudText>
        <MudTooltip Text="Kliknite na simbol da ga ubacite na poziciju kursora u fokusiranom polju. Ctrl+M obavija selektovani tekst u $...$.">
            <MudIconButton Icon="@Icons.Material.Filled.Help" Size="Size.Small" Color="Color.Secondary" />
        </MudTooltip>
        <MudSpacer />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-2">Ctrl+M -> obavij selekciju u $...$</MudText>
    </div>

    <div class="math-helper-grid">
        @foreach (var group in _symbolGroups)
        {
            <div class="math-helper-group">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="math-helper-group-label">@group.Label</MudText>
                <div class="math-helper-buttons">
                    @foreach (var sym in group.Symbols)
                    {
                        var s = sym;
                        <MudTooltip Text="@s.Tooltip" Placement="Placement.Top" Arrow="true">
                            <button class="math-helper-btn" type="button" @onclick="() => InsertAsync(s.Template)">
                                @s.Display
                            </button>
                        </MudTooltip>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IJSObjectReference? _module;

    [Parameter]
    public EventCallback<LatexInsertResult> Inserted { get; set; }

    private record SymbolDef(string Display, string Template, string Tooltip);
    private record SymbolGroup(string Label, SymbolDef[] Symbols);

    private static readonly SymbolGroup[] _symbolGroups =
    [
        new("Razlomci i koreni", [
            new(@"\frac", @"\frac{{}}{}", @"\frac{brojnik}{nazivnik}"),
            new(@"\sqrt", @"\sqrt{{}}", @"\sqrt{izraz}"),
            new(@"\sqrt[n]", @"\sqrt[{}]{}", @"\sqrt[n]{izraz}"),
            new("x^2", "{}^{2}", "Kvadrat"),
            new("x^n", "{}^{{}}", "Stepen"),
            new("x_n", "{}_{{}}",  "Indeks"),
        ]),
        new("Integrali i sume", [
            new(@"\int", @"\int_{{}}^{{}} {}", @"\int_{donja}^{gornja} izraz"),
            new(@"\iint", @"\iint_{{}}", "Dvostruki integral"),
            new(@"\sum", @"\sum_{{{}}}^{{}} {}", @"\sum_{i=0}^{n} izraz"),
            new(@"\prod", @"\prod_{{{}}}^{{}} {}", "Proizvod"),
            new(@"\lim", @"\lim_{{{}}} {}", @"\lim_{x \to 0} izraz"),
        ]),
        new("Funkcije", [
            new("sin", @"\sin({})", "Sinus"),
            new("cos", @"\cos({})", "Kosinus"),
            new("tan", @"\tan({})", "Tangens"),
            new("ln", @"\ln({})", "Prirodni logaritam"),
            new("log", @"\log_{{{}}}({})", "Logaritam"),
        ]),
        new("Granice i relacije", [
            new("<=", @"\leq", "Manje ili jednako"),
            new(">=", @"\geq", "Vece ili jednako"),
            new("!=", @"\neq", "Nije jednako"),
            new("~=", @"\approx", "Priblizno"),
            new("inf", @"\infty", "Beskonacno"),
            new("+-", @"\pm", "Plus-minus"),
            new("->", @"\to", "Strelica desno"),
            new("<->", @"\iff", "Ekvivalencija"),
        ]),
        new("Grcka slova", [
            new("alpha", @"\alpha", "Alpha"),
            new("beta", @"\beta", "Beta"),
            new("gamma", @"\gamma", "Gamma"),
            new("delta", @"\delta", "Delta"),
            new("theta", @"\theta", "Theta"),
            new("lambda", @"\lambda", "Lambda"),
            new("mu", @"\mu", "Mu"),
            new("pi", @"\pi", "Pi"),
            new("sigma", @"\sigma", "Sigma"),
            new("Sigma", @"\Sigma", "Sigma veliko"),
            new("phi", @"\varphi", "Phi"),
            new("omega", @"\omega", "Omega"),
        ]),
        new("Operatori", [
            new("*", @"\cdot", "Tacka mnozenja"),
            new("x", @"\times", "Puta"),
            new("/", @"\div", "Deljeno"),
            new("in", @"\in", "Element skupa"),
            new("notin", @"\notin", "Nije element"),
            new("subset", @"\subset", "Podskup"),
            new("cup", @"\cup", "Unija"),
            new("cap", @"\cap", "Presek"),
            new("forall", @"\forall", "Za svako"),
            new("exists", @"\exists", "Postoji"),
        ]),
        new("Omotaci", [
            new("$...$", "${}$", "Inline matematika"),
            new("$$...$$", "$${}$$", "Display matematika (blok)"),
            new("(...)", @"\left( {} \right)", "Zagrade"),
            new("[...]", @"\left[ {} \right]", "Uglaste zagrade"),
            new("|...|", @"\left| {} \right|", "Apsolutna vrednost"),
            new("||...||", @"\left\| {} \right\|", "Norma"),
        ]),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await Js.InvokeAsync<IJSObjectReference>("import", "/mathEditor.js");
            await _module.InvokeVoidAsync("registerCtrlM", DotNetObjectReference.Create(this));
        }
        catch (Exception)
        {
            // JS not available during prerender.
        }
    }

    private async Task InsertAsync(string template)
    {
        if (_module is null) return;
        try
        {
            var result = await _module.InvokeAsync<LatexInsertResult?>("insertLatexAtCursor", template);
            if (result?.Succeeded == true)
            {
                await Inserted.InvokeAsync(result);
            }
        }
        catch (Exception)
        {
            // Focus may not be on a text field.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregisterCtrlM");
                await _module.DisposeAsync();
            }
            catch { /* ignore disposal errors */ }
        }
    }
}
