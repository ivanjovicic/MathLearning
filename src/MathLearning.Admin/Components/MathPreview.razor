@using MathLearning.Domain.Enums
@using MathRenderMode = MathLearning.Domain.Enums.RenderMode
@using MudBlazor
@implements IAsyncDisposable
@inject IJSRuntime Js
@inject ILogger<MathPreview> Logger

<div class="@($"math-preview-shell {Class}")">
    @if (_isRendering)
    {
        <div class="math-preview-loading">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            <span>Rendering preview...</span>
        </div>
    }
    <div @ref="_container" class="math-preview-host"></div>
</div>

@code {
    private ElementReference _container;
    private bool _needsRender;
    private bool _isRendering;
    private bool _disposed;
    private int _renderVersion;
    private CancellationTokenSource? _renderDebounceCts;
    private string _previousContent = string.Empty;
    private ContentFormat _previousFormat = ContentFormat.MarkdownWithMath;
    private MathRenderMode _previousRenderMode = MathRenderMode.Auto;
    private string _previousEmptyText = string.Empty;
    private IJSObjectReference? _module;

    [Parameter]
    public string? Content { get; set; }

    [Parameter]
    public ContentFormat Format { get; set; } = ContentFormat.MarkdownWithMath;

    [Parameter]
    public MathRenderMode RenderMode { get; set; } = MathRenderMode.Auto;

    [Parameter]
    public string EmptyText { get; set; } = "Nema sadržaja za preview.";

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public int DebounceIntervalMs { get; set; } = 220;

    protected override void OnParametersSet()
    {
        var normalizedContent = Content ?? string.Empty;
        _needsRender =
            normalizedContent != _previousContent ||
            Format != _previousFormat ||
            RenderMode != _previousRenderMode ||
            EmptyText != _previousEmptyText;

        if (_needsRender)
        {
            _renderVersion++;
            _isRendering = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needsRender || _disposed)
        {
            return;
        }

        var version = _renderVersion;
        _renderDebounceCts?.Cancel();
        _renderDebounceCts?.Dispose();
        _renderDebounceCts = new CancellationTokenSource();
        var token = _renderDebounceCts.Token;

        try
        {
            if (DebounceIntervalMs > 0)
            {
                await Task.Delay(DebounceIntervalMs, token);
            }
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (_disposed || token.IsCancellationRequested || version != _renderVersion || !_needsRender)
        {
            return;
        }

        var normalizedContent = Content ?? string.Empty;
        try
        {
            var module = await GetModuleAsync();
            await module.InvokeVoidAsync(
                "render",
                _container,
                normalizedContent,
                Format.ToString(),
                RenderMode.ToString(),
                EmptyText);
        }
        catch (TaskCanceledException)
        {
            Logger.LogDebug("Math preview render canceled.");
            return;
        }
        catch (JSDisconnectedException)
        {
            Logger.LogDebug("Math preview JS interop skipped because the circuit disconnected.");
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Math preview JS rendering failed. The editor will continue without preview.");
        }
        finally
        {
            _previousContent = normalizedContent;
            _previousFormat = Format;
            _previousRenderMode = RenderMode;
            _previousEmptyText = EmptyText;
            _needsRender = false;
            if (_isRendering)
            {
                _isRendering = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<IJSObjectReference> GetModuleAsync()
    {
        _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./mathPreview.js");
        return _module;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _renderDebounceCts?.Cancel();
        _renderDebounceCts?.Dispose();
        _renderDebounceCts = null;

        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            Logger.LogDebug("Math preview JS module dispose skipped because the circuit disconnected.");
        }
    }
}

<style>
    .math-preview-loading {
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(0, 0, 0, 0.64);
        font-size: 0.875rem;
        margin-bottom: 8px;
    }
</style>
