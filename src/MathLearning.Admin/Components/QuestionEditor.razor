    private bool FieldHasError(string? value, ContentFormat format)
        => ContainsBlankMath(value);

    private string? FirstFieldError(string? value, ContentFormat format)
        => ContainsBlankMath(value)
            ? "Prazna LaTeX formula se renderuje kao blank."
            : null;

    private IReadOnlyList<string> GetWarnings(string? value, ContentFormat format) => Sanitizer.GetWarnings(value, format);
    private bool HasWarnings(string? value, ContentFormat format) => GetWarnings(value, format).Count > 0;
    private string WarningFieldClass(string? value, ContentFormat format) => ContainsBlankMath(value) || HasWarnings(value, format) ? "field-with-warning" : string.Empty;

    private RenderFragment RenderFieldGuidance(string? value, ContentFormat format) => builder =>
    {
        var sequence = 0;
        if (ContainsBlankMath(value))
        {
            builder.OpenComponent<MudAlert>(sequence++);
            builder.AddAttribute(sequence++, "Severity", Severity.Error);
            builder.AddAttribute(sequence++, "Dense", true);
            builder.AddAttribute(sequence++, "Class", "inline-warning");
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(inner => inner.AddContent(0, "Formula je prazna. Upisi izraz izmedju $...$ ili ukloni delimitere.")));
            builder.CloseComponent();
        }
        else if (LooksLikeMathWithoutDelimiters(value, format))
        {
            builder.OpenComponent<MudAlert>(sequence++);
            builder.AddAttribute(sequence++, "Severity", Severity.Info);
            builder.AddAttribute(sequence++, "Dense", true);
            builder.AddAttribute(sequence++, "Class", "inline-warning");
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(inner => inner.AddContent(0, "Izgleda kao formula. Ako zelis render matematike, obavij izraz u $...$. Mozes ostaviti i plain tekst.")));
            builder.CloseComponent();
        }

        var warnings = GetWarnings(value, format);
        if (warnings.Count == 0)
        {
            return;
        }

        builder.OpenComponent<MudAlert>(sequence++);
        builder.AddAttribute(sequence++, "Severity", Severity.Warning);
        builder.AddAttribute(sequence++, "Dense", true);
        builder.AddAttribute(sequence++, "Class", "inline-warning");
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(inner =>
        {
            inner.OpenElement(0, "ul");
            inner.AddAttribute(1, "class", "warning-list");
            for (var i = 0; i < warnings.Count; i++)
            {
                inner.OpenElement(2 + i, "li");
                inner.AddContent(3 + i, warnings[i]);
                inner.CloseElement();
            }

            inner.CloseElement();
        }));
        builder.CloseComponent();
    };

    private RenderFragment RenderIssueList(IReadOnlyList<string> issues, string emptyText) => builder =>
    {
        if (issues.Count == 0)
        {
            builder.OpenComponent<MudAlert>(0);
            builder.AddAttribute(1, "Severity", Severity.Success);
            builder.AddAttribute(2, "Dense", true);
            builder.AddAttribute(3, "Class", "mb-3");
            builder.AddAttribute(4, "ChildContent", (RenderFragment)(inner => inner.AddContent(0, "Ovaj korak je spreman.")));
            builder.CloseComponent();
            return;
        }

        var severity = issues.All(issue => issue.StartsWith("Preporuka:", StringComparison.OrdinalIgnoreCase))
            ? Severity.Warning
            : Severity.Error;

        builder.OpenComponent<MudAlert>(0);
        builder.AddAttribute(1, "Severity", severity);
        builder.AddAttribute(2, "Dense", true);
        builder.AddAttribute(3, "Class", "mb-3");
        builder.AddAttribute(4, "ChildContent", (RenderFragment)(inner =>
        {
            inner.AddContent(0, emptyText);
            inner.OpenElement(1, "ul");
            inner.AddAttribute(2, "class", "warning-list mt-1");
            for (var i = 0; i < issues.Count; i++)
            {
                inner.OpenElement(3 + i, "li");
                inner.AddContent(4 + i, issues[i]);
                inner.CloseElement();
            }

            inner.CloseElement();
        }));
        builder.CloseComponent();
    };

    private static bool ContainsBlankMath(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        return Regex.IsMatch(value, @"\$\s*\$") || Regex.IsMatch(value, @"\$\$\s*\$\$");
    }

    private static bool LooksLikeMathWithoutDelimiters(string? value, ContentFormat format)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Contains('$') || format == ContentFormat.PlainText)
        {
            return false;
        }

        return value.Contains('\\') ||
               value.Contains('^') ||
               value.Contains("_") ||
               value.Contains(@"\frac", StringComparison.OrdinalIgnoreCase) ||
               value.Contains(@"\sqrt", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetRenderModeLabel(MathRenderMode mode) => mode switch
    {
        MathRenderMode.Auto => "Auto",
        MathRenderMode.Inline => "Inline",
        MathRenderMode.Display => "Display",
        _ => mode.ToString()
    };

    private static string GetFormatLabel(ContentFormat format) => format switch
    {
        ContentFormat.PlainText => "Plain text",
        ContentFormat.LaTeX => "LaTeX",
        ContentFormat.MarkdownWithMath => "Markdown + Math",
        ContentFormat.Html => "HTML",
        _ => format.ToString()
    };

    private static string FormatSubtopic(Subtopic subtopic)
        => subtopic.Topic is null ? subtopic.Name : $"{subtopic.Topic.Name} / {subtopic.Name}";

    private static string GetOptionLetter(int index)
        => ((char)('A' + index)).ToString();
