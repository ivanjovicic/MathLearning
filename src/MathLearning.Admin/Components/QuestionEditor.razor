@using MathLearning.Admin.Models
@using MathLearning.Application.Content
@using MathLearning.Domain.Entities
@using MathLearning.Domain.Enums
@using MathRenderMode = MathLearning.Domain.Enums.RenderMode
@inject IMathContentSanitizer Sanitizer

<div class="editor-container">
    <MudGrid Spacing="3">
        <MudItem xs="12" lg="8">
            <MudTabs Elevation="3" Class="mud-height-full" @bind-ActivePanelIndex="_activeTabIndex">
                <MudTabPanel Text="Tekst pitanja" Icon="@Icons.Material.Filled.Notes">
                    <MudGrid Spacing="2" Class="pa-4">
                        <MudItem xs="12" md="4">
                            <MudSelect T="string" Label="Tip pitanja" @bind-Value="Model.Type" Variant="Variant.Outlined">
                                <MudSelectItem T="string" Value="@("multiple_choice")">Visestruki izbor</MudSelectItem>
                                <MudSelectItem T="string" Value="@("open_answer")">Otvoren odgovor</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="int" Label="Kategorija" @bind-Value="Model.CategoryId" Variant="Variant.Outlined">
                                @foreach (var category in Categories)
                                {
                                    <MudSelectItem T="int" Value="@category.Id">@category.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="int" Label="Podtema" @bind-Value="Model.SubtopicId" Variant="Variant.Outlined">
                                @foreach (var subtopic in Subtopics)
                                {
                                    <MudSelectItem T="int" Value="@subtopic.Id">@FormatSubtopic(subtopic)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="8">
                            <MudTextField T="string" Label="Tekst pitanja" Variant="Variant.Outlined" Lines="4" AutoGrow="true" DebounceInterval="300"
                                          Error="@HasWarnings(Model.Text, Model.TextFormat)"
                                          ErrorText="@FirstWarning(Model.Text, Model.TextFormat)"
                                          Class="@WarningFieldClass(Model.Text, Model.TextFormat)"
                                          MaxLength="@QuestionEditorFieldLimits.QuestionTextMaxLength"
                                          HelperText="@($"{Model.Text?.Length ?? 0} / {QuestionEditorFieldLimits.QuestionTextMaxLength}")"
                                          @bind-Value="Model.Text" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="ContentFormat" Label="Format" @bind-Value="Model.TextFormat" Variant="Variant.Outlined">
                                @foreach (var format in EditorFormats)
                                {
                                    <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="MathRenderMode" Label="Render" @bind-Value="Model.TextRenderMode" Variant="Variant.Outlined">
                                @foreach (var renderMode in RenderModes)
                                {
                                    <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">@RenderWarnings(Model.Text, Model.TextFormat)</MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string" Label="Semantics alt text" Variant="Variant.Outlined" DebounceInterval="300"
                                          HelperText="Opcionalno. Ako ostane prazno, backend generise citljiv fallback."
                                          @bind-Value="Model.SemanticsAltText" />
                        </MudItem>

                        <MudItem xs="12" md="8">
                            <MudText Typo="Typo.body2" Class="mb-1">Tezina</MudText>
                            <MudSlider T="int" Min="1" Max="5" Step="1" ValueLabel="true" @bind-Value="Model.Difficulty" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.body2" Class="mb-1">Izabrana tezina</MudText>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">@($"{Model.Difficulty} / 5")</MudChip>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Opcije / Odgovori" Icon="@Icons.Material.Filled.ListAlt">
                    <MudGrid Spacing="2" Class="pa-4">
                        @if (IsMultipleChoice)
                        {
                            <MudItem xs="12">
                                <div class="editor-header">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.h6">Opcije odgovora</MudText>
                                        @if (HasDuplicateOptions)
                                        {
                                            <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.Warning" Size="Size.Small">Duplikati</MudChip>
                                        }
                                    </div>
                                    <MudTooltip Text="Ctrl+Enter u polju teksta dodaje novu opciju">
                                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                   OnClick="AddOption" Disabled="@(Model.Options.Count >= 8)">
                                            Dodaj opciju
                                        </MudButton>
                                    </MudTooltip>
                                </div>
                            </MudItem>

                            @for (var i = 0; i < Model.Options.Count; i++)
                            {
                                var option = Model.Options[i];
                                var idx = i;
                                var isDup = IsDuplicateOption(idx);
                                var cardClass = option.IsCorrect
                                    ? "pa-3 option-card option-card-correct"
                                    : (isDup ? "pa-3 option-card option-card-duplicate" : "pa-3 option-card");
                                <MudItem xs="12">
                                    <div draggable="true"
                                         @ondragstart="@(() => _dragFromIndex = idx)"
                                         @ondragover:preventDefault
                                         @ondrop="@(() => DropOption(idx))">
                                        <MudPaper Class="@cardClass" Outlined="true">
                                            <div class="editor-header">
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                                             Class="option-drag-handle" Size="Size.Small" />
                                                    @if (option.IsCorrect)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                        <MudText Typo="Typo.subtitle2" Color="Color.Success" Style="font-weight:600">Opcija @(idx + 1) — Tačan odgovor</MudText>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.subtitle2">Opcija @(idx + 1)</MudText>
                                                    }
                                                    @if (isDup)
                                                    {
                                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                                                 Icon="@Icons.Material.Filled.ContentCopy">Duplikat</MudChip>
                                                    }
                                                </div>
                                                <div class="editor-actions">
                                                    <MudTooltip Text="@(option.IsCorrect ? "Tačan odgovor" : "Označi kao tačan")">
                                                        <MudIconButton Icon="@(option.IsCorrect ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.RadioButtonUnchecked)"
                                                                       Color="@(option.IsCorrect ? Color.Success : Color.Default)"
                                                                       OnClick="@(() => MarkCorrect(idx))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Ukloni opciju">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                                       Disabled="@(Model.Options.Count <= 2)"
                                                                       OnClick="@(() => RemoveOption(idx))" />
                                                    </MudTooltip>
                                                </div>
                                            </div>

                                            <MudGrid Spacing="2">
                                                <MudItem xs="12" md="8">
                                                    <div @onkeydown="@(e => HandleOptionKeyDown(e, idx))">
                                                        <MudTextField T="string" Label="Tekst opcije" Variant="Variant.Outlined" Lines="2" AutoGrow="true" DebounceInterval="300"
                                                                      Error="@HasWarnings(option.Text, option.TextFormat)"
                                                                      ErrorText="@FirstWarning(option.Text, option.TextFormat)"
                                                                      Class="@WarningFieldClass(option.Text, option.TextFormat)"
                                                                      MaxLength="@QuestionEditorFieldLimits.OptionTextMaxLength"
                                                                      HelperText="@($"{option.Text?.Length ?? 0} / {QuestionEditorFieldLimits.OptionTextMaxLength}")"
                                                                      @bind-Value="option.Text" />
                                                    </div>
                                                </MudItem>
                                                <MudItem xs="12" md="2">
                                                    <MudSelect T="ContentFormat" Label="Format" @bind-Value="option.TextFormat" Variant="Variant.Outlined">
                                                        @foreach (var format in EditorFormats)
                                                        {
                                                            <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </MudItem>
                                                <MudItem xs="12" md="2">
                                                    <MudSelect T="MathRenderMode" Label="Render" @bind-Value="option.RenderMode" Variant="Variant.Outlined">
                                                        @foreach (var renderMode in RenderModes)
                                                        {
                                                            <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </MudItem>
                                                <MudItem xs="12">@RenderWarnings(option.Text, option.TextFormat)</MudItem>
                                                <MudItem xs="12">
                                                    <MudTextField T="string" Label="Semantics alt text" Variant="Variant.Outlined" DebounceInterval="300" @bind-Value="option.SemanticsAltText" />
                                                </MudItem>
                                            </MudGrid>
                                        </MudPaper>
                                    </div>
                                </MudItem>
                            }
                        }
                        else
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6" Class="mb-3">Tacan odgovor</MudText>
                                <MudTextField T="string" Label="Tacan odgovor" Variant="Variant.Outlined" Lines="2" AutoGrow="true" DebounceInterval="300"
                                              Error="@HasWarnings(Model.CorrectAnswer, Model.TextFormat)"
                                              ErrorText="@FirstWarning(Model.CorrectAnswer, Model.TextFormat)"
                                              Class="@WarningFieldClass(Model.CorrectAnswer, Model.TextFormat)"
                                              MaxLength="@QuestionEditorFieldLimits.CorrectAnswerMaxLength"
                                              HelperText="@($"{Model.CorrectAnswer?.Length ?? 0} / {QuestionEditorFieldLimits.CorrectAnswerMaxLength}")"
                                              @bind-Value="Model.CorrectAnswer" />
                                @RenderWarnings(Model.CorrectAnswer, Model.TextFormat)
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Koraci resenja" Icon="@Icons.Material.Filled.ViewAgenda">
                    <MudGrid Spacing="2" Class="pa-4">
                        <MudItem xs="12">
                            <div class="editor-header">
                                <MudText Typo="Typo.h6">Koraci resenja</MudText>
                                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddStep">
                                    Dodaj korak
                                </MudButton>
                            </div>
                        </MudItem>

                        @if (Model.Steps.Count == 0)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info">Koraci su opcioni, ali preporuceni za pitanja sa objasnjenjem.</MudAlert>
                            </MudItem>
                        }

                        @for (var i = 0; i < Model.Steps.Count; i++)
                        {
                            var step = Model.Steps[i];
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 step-card" Outlined="true">
                                    <div class="editor-header">
                                        <MudText Typo="Typo.subtitle2">Korak @(i + 1)</MudText>
                                        <div class="editor-actions">
                                            <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Disabled="@(i == 0)" OnClick="@(() => MoveStep(i, -1))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Disabled="@(i == Model.Steps.Count - 1)" OnClick="@(() => MoveStep(i, 1))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveStep(i))" />
                                        </div>
                                    </div>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" md="8">
                                            <MudTextField T="string" Label="Tekst koraka" Variant="Variant.Outlined" Lines="3" AutoGrow="true" DebounceInterval="300"
                                                          Error="@HasWarnings(step.Text, step.TextFormat)"
                                                          ErrorText="@FirstWarning(step.Text, step.TextFormat)"
                                                          Class="@WarningFieldClass(step.Text, step.TextFormat)"
                                                          MaxLength="@QuestionEditorFieldLimits.StepTextMaxLength"
                                                          HelperText="@($"{step.Text?.Length ?? 0} / {QuestionEditorFieldLimits.StepTextMaxLength}")"
                                                          @bind-Value="step.Text" />
                                        </MudItem>
                                        <MudItem xs="12" md="2">
                                            <MudSelect T="ContentFormat" Label="Format" @bind-Value="step.TextFormat" Variant="Variant.Outlined">
                                                @foreach (var format in EditorFormats)
                                                {
                                                    <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="2">
                                            <MudSelect T="MathRenderMode" Label="Render" @bind-Value="step.TextRenderMode" Variant="Variant.Outlined">
                                                @foreach (var renderMode in RenderModes)
                                                {
                                                    <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="8">
                                            <MudTextField T="string" Label="Hint uz korak" Variant="Variant.Outlined" Lines="2" AutoGrow="true" DebounceInterval="300"
                                                          Error="@HasWarnings(step.Hint, step.HintFormat)"
                                                          ErrorText="@FirstWarning(step.Hint, step.HintFormat)"
                                                          Class="@WarningFieldClass(step.Hint, step.HintFormat)"
                                                          @bind-Value="step.Hint" />
                                        </MudItem>
                                        <MudItem xs="12" md="2">
                                            <MudSelect T="ContentFormat" Label="Hint format" @bind-Value="step.HintFormat" Variant="Variant.Outlined">
                                                @foreach (var format in EditorFormats)
                                                {
                                                    <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12" md="2">
                                            <MudSelect T="MathRenderMode" Label="Hint render" @bind-Value="step.HintRenderMode" Variant="Variant.Outlined">
                                                @foreach (var renderMode in RenderModes)
                                                {
                                                    <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">@RenderWarnings(step.Text, step.TextFormat)@RenderWarnings(step.Hint, step.HintFormat)</MudItem>
                                        <MudItem xs="12" md="8">
                                            <MudTextField T="string" Label="Semantics alt text" Variant="Variant.Outlined" DebounceInterval="300" @bind-Value="step.SemanticsAltText" />
                                        </MudItem>
                                        <MudItem xs="12" md="4">
                                            <MudCheckBox T="bool" @bind-Value="step.Highlight" Label="Istakni korak" />
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Objasnjenje i hintovi" Icon="@Icons.Material.Filled.Help">
                    <MudGrid Spacing="2" Class="pa-4">
                        <MudItem xs="12" md="8">
                            <MudTextField T="string" Label="Objasnjenje" Variant="Variant.Outlined" Lines="5" AutoGrow="true" DebounceInterval="300"
                                          Error="@HasWarnings(Model.Explanation, Model.ExplanationFormat)"
                                          ErrorText="@FirstWarning(Model.Explanation, Model.ExplanationFormat)"
                                          Class="@WarningFieldClass(Model.Explanation, Model.ExplanationFormat)"
                                          MaxLength="@QuestionEditorFieldLimits.ExplanationMaxLength"
                                          HelperText="@($"{Model.Explanation?.Length ?? 0} / {QuestionEditorFieldLimits.ExplanationMaxLength}")"
                                          @bind-Value="Model.Explanation" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="ContentFormat" Label="Format" @bind-Value="Model.ExplanationFormat" Variant="Variant.Outlined">
                                @foreach (var format in EditorFormats)
                                {
                                    <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="MathRenderMode" Label="Render" @bind-Value="Model.ExplanationRenderMode" Variant="Variant.Outlined">
                                @foreach (var renderMode in RenderModes)
                                {
                                    <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">@RenderWarnings(Model.Explanation, Model.ExplanationFormat)</MudItem>

                        <MudItem xs="12"><MudDivider /></MudItem>
                        <MudItem xs="12"><MudText Typo="Typo.h6" Class="mb-3">Hintovi</MudText></MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="ContentFormat" Label="Hint format" @bind-Value="Model.HintFormat" Variant="Variant.Outlined">
                                @foreach (var format in EditorFormats)
                                {
                                    <MudSelectItem T="ContentFormat" Value="@format">@GetFormatLabel(format)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="MathRenderMode" Label="Hint render" @bind-Value="Model.HintRenderMode" Variant="Variant.Outlined">
                                @foreach (var renderMode in RenderModes)
                                {
                                    <MudSelectItem T="MathRenderMode" Value="@renderMode">@renderMode</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4"></MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField T="string" Label="Hint formula" Variant="Variant.Outlined" Lines="3" AutoGrow="true" DebounceInterval="300"
                                          Error="@HasWarnings(Model.HintFormula, Model.HintFormat)"
                                          ErrorText="@FirstWarning(Model.HintFormula, Model.HintFormat)"
                                          Class="@WarningFieldClass(Model.HintFormula, Model.HintFormat)"
                                          @bind-Value="Model.HintFormula" />
                            @RenderWarnings(Model.HintFormula, Model.HintFormat)
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField T="string" Label="Hint clue" Variant="Variant.Outlined" Lines="3" AutoGrow="true" DebounceInterval="300"
                                          Error="@HasWarnings(Model.HintClue, Model.HintFormat)"
                                          ErrorText="@FirstWarning(Model.HintClue, Model.HintFormat)"
                                          Class="@WarningFieldClass(Model.HintClue, Model.HintFormat)"
                                          @bind-Value="Model.HintClue" />
                            @RenderWarnings(Model.HintClue, Model.HintFormat)
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField T="string" Label="Hint full" Variant="Variant.Outlined" Lines="3" AutoGrow="true" DebounceInterval="300"
                                          Error="@HasWarnings(Model.HintFull, Model.HintFormat)"
                                          ErrorText="@FirstWarning(Model.HintFull, Model.HintFormat)"
                                          Class="@WarningFieldClass(Model.HintFull, Model.HintFormat)"
                                          @bind-Value="Model.HintFull" />
                            @RenderWarnings(Model.HintFull, Model.HintFormat)
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </MudItem>
        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 preview-panel" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">Live Preview</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">Preview se osvezava samo kada se sadrzaj promeni.</MudText>

                @if (_activeTabIndex == 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Pitanje</MudText>
                    <MathPreview Content="@Model.Text" Format="@Model.TextFormat" RenderMode="@Model.TextRenderMode" />
                }
                else if (_activeTabIndex == 1)
                {
                    @if (IsMultipleChoice)
                    {
                        @for (var i = 0; i < Model.Options.Count; i++)
                        {
                            <MudText Typo="Typo.caption" Class="mb-1">Opcija @(i + 1)@(Model.Options[i].IsCorrect ? " (tacna)" : string.Empty)</MudText>
                            <MathPreview Content="@Model.Options[i].Text" Format="@Model.Options[i].TextFormat" RenderMode="@Model.Options[i].RenderMode" Class="mb-2" />
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Tacan odgovor</MudText>
                        <MathPreview Content="@Model.CorrectAnswer" Format="@Model.TextFormat" RenderMode="@Model.TextRenderMode" />
                    }
                }
                else if (_activeTabIndex == 2)
                {
                    @if (Model.Steps.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Dodaj korake da bi se prikazao preview.</MudAlert>
                    }
                    else
                    {
                        @for (var i = 0; i < Model.Steps.Count; i++)
                        {
                            <MudText Typo="Typo.caption" Class="mb-1">Korak @(i + 1)</MudText>
                            <MathPreview Content="@Model.Steps[i].Text" Format="@Model.Steps[i].TextFormat" RenderMode="@Model.Steps[i].TextRenderMode" Class="mb-2" />
                        }
                    }
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Objasnjenje</MudText>
                    <MathPreview Content="@Model.Explanation" Format="@Model.ExplanationFormat" RenderMode="@Model.ExplanationRenderMode" Class="mb-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Hint formula</MudText>
                    <MathPreview Content="@Model.HintFormula" Format="@Model.HintFormat" RenderMode="@Model.HintRenderMode" Class="mb-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Hint clue</MudText>
                    <MathPreview Content="@Model.HintClue" Format="@Model.HintFormat" RenderMode="@Model.HintRenderMode" Class="mb-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Hint full</MudText>
                    <MathPreview Content="@Model.HintFull" Format="@Model.HintFormat" RenderMode="@Model.HintRenderMode" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2" Class="mt-4">
        <MudItem xs="12">
            <div class="editor-actions footer-actions">
                <MudButton OnClick="@(() => OnSave.InvokeAsync())"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        <span>Cuvanje...</span>
                    }
                    else
                    {
                        <span>@SaveButtonText</span>
                    }
                </MudButton>

                <MudButton Href="@BackHref"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Nazad
                </MudButton>
            </div>

            @if (ValidationErrors?.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">
                    <ul class="mb-0">
                        @foreach (var error in ValidationErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </MudAlert>
            }
        </MudItem>
    </MudGrid>
</div>

@code {
    private static readonly ContentFormat[] EditorFormats =
    [
        ContentFormat.PlainText,
        ContentFormat.Latex,
        ContentFormat.MarkdownWithMath
    ];

    private static readonly MathRenderMode[] RenderModes =
    [
        MathRenderMode.Auto,
        MathRenderMode.Inline,
        MathRenderMode.Display
    ];

    private int _activeTabIndex;
    private int _dragFromIndex = -1;
    private bool HasDuplicateOptions => IsMultipleChoice && Enumerable.Range(0, Model.Options.Count).Any(IsDuplicateOption);

    [Parameter, EditorRequired]
    public QuestionEditorModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyList<Category> Categories { get; set; } = [];

    [Parameter]
    public IReadOnlyList<Subtopic> Subtopics { get; set; } = [];

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public string SaveButtonText { get; set; } = "Sacuvaj pitanje";

    [Parameter]
    public string BackHref { get; set; } = "/questions";

    [Parameter]
    public IReadOnlyList<string> ValidationErrors { get; set; } = [];

    [Parameter]
    public EventCallback OnSave { get; set; }

    private bool IsMultipleChoice => string.Equals(Model.Type, "multiple_choice", StringComparison.OrdinalIgnoreCase);

    private void AddOption() => Model.Options.Add(new QuestionOptionEditorModel());

    private void RemoveOption(int index)
    {
        if (index < 0 || index >= Model.Options.Count) return;
        Model.Options.RemoveAt(index);
        if (Model.Options.All(x => !x.IsCorrect) && Model.Options.Count > 0) Model.Options[0].IsCorrect = true;
    }

    private void MarkCorrect(int index)
    {
        for (var i = 0; i < Model.Options.Count; i++) Model.Options[i].IsCorrect = i == index;
    }

    private void AddStep() => Model.Steps.Add(new QuestionStepEditorModel { Order = Model.Steps.Count + 1 });

    private void RemoveStep(int index)
    {
        if (index < 0 || index >= Model.Steps.Count) return;
        Model.Steps.RemoveAt(index);
        NormalizeStepOrder();
    }

    private void MoveStep(int index, int direction)
    {
        var target = index + direction;
        if (index < 0 || index >= Model.Steps.Count || target < 0 || target >= Model.Steps.Count) return;
        (Model.Steps[index], Model.Steps[target]) = (Model.Steps[target], Model.Steps[index]);
        NormalizeStepOrder();
    }

    private void NormalizeStepOrder()
    {
        for (var i = 0; i < Model.Steps.Count; i++) Model.Steps[i].Order = i + 1;
    }

    private void DropOption(int toIndex)
    {
        if (_dragFromIndex < 0 || _dragFromIndex == toIndex) { _dragFromIndex = -1; return; }
        var item = Model.Options[_dragFromIndex];
        Model.Options.RemoveAt(_dragFromIndex);
        Model.Options.Insert(toIndex, item);
        _dragFromIndex = -1;
    }

    private bool IsDuplicateOption(int index)
    {
        var text = Model.Options[index].Text?.Trim();
        if (string.IsNullOrEmpty(text)) return false;
        return Model.Options
            .Where((_, i) => i != index)
            .Any(o => string.Equals(o.Text?.Trim(), text, StringComparison.OrdinalIgnoreCase));
    }

    private void HandleOptionKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.CtrlKey && e.Key == "Enter" && Model.Options.Count < 8)
        {
            AddOption();
        }
    }

    private IReadOnlyList<string> GetWarnings(string? value, ContentFormat format) => Sanitizer.GetWarnings(value, format);
    private bool HasWarnings(string? value, ContentFormat format) => GetWarnings(value, format).Count > 0;
    private string? FirstWarning(string? value, ContentFormat format) => GetWarnings(value, format).FirstOrDefault();
    private string WarningFieldClass(string? value, ContentFormat format) => HasWarnings(value, format) ? "field-with-warning" : string.Empty;

    private string GetFormatLabel(ContentFormat format) => format switch
    {
        ContentFormat.PlainText => "Plain text",
        ContentFormat.Latex => "LaTeX",
        ContentFormat.MarkdownWithMath => "Markdown + Math",
        ContentFormat.Html => "HTML",
        _ => format.ToString()
    };

    private string FormatSubtopic(Subtopic subtopic) => subtopic.Topic is null ? subtopic.Name : $"{subtopic.Topic.Name} / {subtopic.Name}";

    private RenderFragment RenderWarnings(string? value, ContentFormat format) => builder =>
    {
        var warnings = GetWarnings(value, format);
        if (warnings.Count == 0) return;

        builder.OpenComponent<MudAlert>(0);
        builder.AddAttribute(1, "Severity", Severity.Warning);
        builder.AddAttribute(2, "Dense", true);
        builder.AddAttribute(3, "Class", "inline-warning");
        builder.AddAttribute(4, "ChildContent", (RenderFragment)(inner =>
        {
            inner.OpenElement(0, "ul");
            inner.AddAttribute(1, "class", "warning-list");
            for (var i = 0; i < warnings.Count; i++)
            {
                inner.OpenElement(2 + i, "li");
                inner.AddContent(3 + i, warnings[i]);
                inner.CloseElement();
            }
            inner.CloseElement();
        }));
        builder.CloseComponent();
    };
}

