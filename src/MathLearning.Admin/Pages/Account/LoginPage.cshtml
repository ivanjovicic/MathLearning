@page "/login-page"
@model MathLearning.Admin.Pages.Account.LoginPageModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MathLearning Admin</title>
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="/_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: Roboto, Helvetica, Arial, sans-serif;
        }
        .login-container {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 400px;
        }
        h1 {
            margin: 0 0 30px 0;
            font-size: 2rem;
            font-weight: 400;
            color: #424242;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            color: #616161;
            font-size: 0.875rem;
        }
        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 16px 14px;
            border: 1px solid #bdbdbd;
            border-radius: 4px;
            font-size: 1rem;
            box-sizing: border-box;
            font-family: inherit;
        }
        input[type="text"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #594ae2;
            border-width: 2px;
            padding: 15px 13px;
        }
        button {
            width: 100%;
            padding: 12px;
            background: #594ae2;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 0.875rem;
            font-weight: 500;
            text-transform: uppercase;
            cursor: pointer;
            letter-spacing: 0.02857em;
        }
        button:hover {
            background: #4a3bc2;
        }
        button:disabled {
            background: #bdbdbd;
            cursor: not-allowed;
        }
        .error {
            background: #ffebee;
            color: #c62828;
            padding: 12px 16px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 0.875rem;
        }
        .info {
            text-align: center;
            margin-top: 20px;
            color: #757575;
            font-size: 0.75rem;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h1>Prijava</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label for="username">Korisni?ko ime</label>
                <input type="text" id="username" name="username" required autofocus />
            </div>

            <div class="form-group">
                <label for="password">Lozinka</label>
                <input type="password" id="password" name="password" required />
            </div>

            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <button type="submit">Prijavi se</button>

            <div class="info">
                Podrazumevano: admin / UcimMatu!123
            </div>
        </form>
    </div>
</body>
</html>
