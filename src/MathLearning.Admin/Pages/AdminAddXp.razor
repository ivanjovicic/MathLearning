@page "/admin/add-xp"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Services
@using System.Text.Json
@using MudBlazor

<PageTitle>Dodeli XP korisniku</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Admin: Ručno dodeli XP korisniku</MudText>

<MudPaper Class="pa-4" Elevation="4">
    <MudTextField @bind-Value="userId" Label="User ID" Variant="Variant.Outlined" Class="mb-4" />
    <MudNumericField @bind-Value="amount" Label="XP iznos (+/-)" Variant="Variant.Outlined" Class="mb-4" />
    <MudButton OnClick="AddXp" Color="Color.Success" Variant="Variant.Filled" Disabled="isLoading || string.IsNullOrWhiteSpace(userId) || amount == 0">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            <span>Slanje...</span>
        }
        else
        {
            <span>Dodeli XP</span>
        }
    </MudButton>
    @if (!string.IsNullOrEmpty(resultMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">@resultMessage</MudAlert>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
    }
</MudPaper>

@code {
    [Inject] private AdminApiClient Api { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private string userId = string.Empty;
    private int amount = 0;
    private string? resultMessage;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task AddXp()
    {
        var amountAction = amount > 0 ? "dodati" : "oduzeti";
        var confirmMessage = $"Da li ste sigurni da želite da {amountAction} {Math.Abs(amount)} XP korisniku '{userId}'?";
        
        var confirmed = await DialogService.ShowMessageBox(
            "Potvrda",
            confirmMessage,
            yesText: "Potvrdi",
            cancelText: "Otkaži");

        if (confirmed != true)
        {
            return;
        }

        resultMessage = null;
        errorMessage = null;
        isLoading = true;
        try
        {
            var resp = await Api.PostAsJsonAsync($"/api/leaderboard/admin/add-xp/{userId}", new { amount });
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadFromJsonAsync<JsonElement>();
                resultMessage = json.TryGetProperty("message", out var msgProp)
                    ? msgProp.GetString()
                    : "XP ažuriran.";
                Snackbar.Add("XP je uspešno ažuriran", Severity.Success);
            }
            else
            {
                errorMessage = $"Greška: {resp.StatusCode}";
                Snackbar.Add($"Greška pri ažuriranju XP: {resp.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
            Snackbar.Add($"Greška pri ažuriranju XP: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
