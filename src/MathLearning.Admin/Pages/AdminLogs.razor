@page "/admin/logs"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using System.Net.Http.Json
@using MudBlazor

<PageTitle>Logovi i status pozadinskih poslova</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Logovi i status XP/Leaderboard poslova</MudText>

<MudPaper Class="pa-4" Elevation="4">
    <MudButton OnClick="Refresh" Color="Color.Primary" Variant="Variant.Filled" Disabled="isLoading">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            <span>Učitavanje...</span>
        }
        else
        {
            <span>Osveži</span>
        }
    </MudButton>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
    }
    <MudTable Dense="true" Class="mt-4" Items="@jobs">
        <HeaderContent>
            <MudTh>Job</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Poslednja poruka</MudTh>
            <MudTh>Vreme</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                @if (context.IsSuccess)
                {
                    <MudChip Color="Color.Success">OK</MudChip>
                }
                else
                {
                    <MudChip Color="Color.Error">Greška</MudChip>
                }
            </MudTd>
            <MudTd>@context.LastMessage</MudTd>
            <MudTd>@context.Timestamp.ToString("g")</MudTd>
        </RowTemplate>
    </MudTable>
    <MudDivider Class="my-4" />
    <MudText Typo="Typo.h6">Poslednjih 20 logova (XP/Leaderboard)</MudText>
    <MudList Dense="true">
        @foreach (var log in logs)
        {
            <MudListItem>@log</MudListItem>
        }
    </MudList>
</MudPaper>

@code {
    private List<JobStatus> jobs = new();
    private List<string> logs = new();
    private string? errorMessage;
    private bool isLoading = false;

    private async Task Refresh()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            var http = new HttpClient { BaseAddress = new Uri(NavManager.BaseUri) };
            // Pretpostavljamo da postoji endpoint /api/monitoring/jobs i /api/monitoring/logs
            jobs = await http.GetFromJsonAsync<List<JobStatus>>("/api/monitoring/jobs") ?? new();
            logs = await http.GetFromJsonAsync<List<string>>("/api/monitoring/logs") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public class JobStatus
    {
        public string Name { get; set; } = string.Empty;
        public bool IsSuccess { get; set; }
        public string LastMessage { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }

    [Inject] NavigationManager NavManager { get; set; } = default!;
}
