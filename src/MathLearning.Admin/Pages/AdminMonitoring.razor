@page "/admin/monitoring"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using System.Net.Http.Json
@using MudBlazor

<PageTitle>Monitoring i status servisa</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Monitoring: Pozadinski servisi i status</MudText>

<MudPaper Class="pa-4" Elevation="4">
    <MudButton OnClick="Refresh" Color="Color.Primary" Variant="Variant.Filled" Disabled="isLoading">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            <span>Učitavanje...</span>
        }
        else
        {
            <span>Osveži</span>
        }
    </MudButton>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
    }
    <MudTable Dense="true" Class="mt-4" Items="@statuses">
        <HeaderContent>
            <MudTh>Servis</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Detalji</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                @if (context.IsHealthy)
                {
                    <MudChip Color="Color.Success">OK</MudChip>
                }
                else
                {
                    <MudChip Color="Color.Error">Greška</MudChip>
                }
            </MudTd>
            <MudTd>@context.Details</MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<ServiceStatus> statuses = new();
    private string? errorMessage;
    private bool isLoading = false;

    private async Task Refresh()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            var http = new HttpClient { BaseAddress = new Uri(NavManager.BaseUri) };
            // Health endpoint
            var health = await http.GetAsync("/health");
            statuses = new List<ServiceStatus>
            {
                new ServiceStatus {
                    Name = "API Health",
                    IsHealthy = health.IsSuccessStatusCode,
                    Details = health.IsSuccessStatusCode ? "API radi" : $"Status: {health.StatusCode}"
                }
            };
            // Hangfire dashboard (just check if reachable)
            var hangfire = await http.GetAsync("/hangfire");
            statuses.Add(new ServiceStatus {
                Name = "Hangfire Dashboard",
                IsHealthy = hangfire.IsSuccessStatusCode,
                Details = hangfire.IsSuccessStatusCode ? "Dashboard OK" : $"Status: {hangfire.StatusCode}"
            });
            // Metrics endpoint
            var metrics = await http.GetAsync("/metrics");
            statuses.Add(new ServiceStatus {
                Name = "API Metrics",
                IsHealthy = metrics.IsSuccessStatusCode,
                Details = metrics.IsSuccessStatusCode ? "Dostupno" : $"Status: {metrics.StatusCode}"
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    public class ServiceStatus
    {
        public string Name { get; set; } = string.Empty;
        public bool IsHealthy { get; set; }
        public string Details { get; set; } = string.Empty;
    }

    [Inject] NavigationManager NavManager { get; set; } = default!;
}
