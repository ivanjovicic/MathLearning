@page "/admin/reset-xp"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using System.Net.Http.Json
@using System.Text.Json
@using MudBlazor

<PageTitle>Resetuj XP korisnika</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Admin: Resetuj XP korisnika</MudText>

<MudPaper Class="pa-4" Elevation="4">
    <MudTextField @bind-Value="userId" Label="User ID" Variant="Variant.Outlined" Class="mb-4" />
    <MudButton OnClick="ResetXp" Color="Color.Error" Variant="Variant.Filled" Disabled="isLoading || string.IsNullOrWhiteSpace(userId)">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            <span>Resetovanje...</span>
        }
        else
        {
            <span>Resetuj XP</span>
        }
    </MudButton>
    @if (!string.IsNullOrEmpty(resultMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">@resultMessage</MudAlert>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
    }
</MudPaper>

@code {
    private string userId = string.Empty;
    private string? resultMessage;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task ResetXp()
    {
        resultMessage = null;
        errorMessage = null;
        isLoading = true;
        try
        {
            var http = new HttpClient { BaseAddress = new Uri(NavManager.BaseUri) };
            var response = await http.PostAsync($"/api/leaderboard/admin/reset-xp/{userId}", null);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<JsonElement>();
                resultMessage = json.GetProperty("message").GetString();
            }
            else
            {
                errorMessage = $"Greška: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    [Inject] NavigationManager NavManager { get; set; } = default!;
}
