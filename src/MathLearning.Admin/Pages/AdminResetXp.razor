@page "/admin/reset-xp"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Services
@using System.Text.Json
@using MudBlazor

<PageTitle>Resetuj XP korisnika</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Admin: Resetuj XP korisnika</MudText>

<MudPaper Class="pa-4" Elevation="4">
    <MudTextField @bind-Value="userId" Label="User ID" Variant="Variant.Outlined" Class="mb-4" />
    <MudButton OnClick="ResetXp" Color="Color.Error" Variant="Variant.Filled" Disabled="isLoading || string.IsNullOrWhiteSpace(userId)">
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            <span>Resetovanje...</span>
        }
        else
        {
            <span>Resetuj XP</span>
        }
    </MudButton>
    @if (!string.IsNullOrEmpty(resultMessage))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">@resultMessage</MudAlert>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
    }
</MudPaper>

@code {
    [Inject] private AdminApiClient Api { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private string userId = string.Empty;
    private string? resultMessage;
    private string? errorMessage;
    private bool isLoading = false;

    private async Task ResetXp()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Potvrda brisanja",
            $"Da li ste sigurni da želite da resetujete sve XP vrednosti za korisnika '{userId}'? Ovo je nepovratna akcija.",
            yesText: "Resetuj XP",
            cancelText: "Otkaži");

        if (confirmed != true)
        {
            return;
        }

        resultMessage = null;
        errorMessage = null;
        isLoading = true;
        try
        {
            var response = await Api.PostAsync($"/api/leaderboard/admin/reset-xp/{userId}", null);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<JsonElement>();
                resultMessage = json.GetProperty("message").GetString();
                Snackbar.Add("XP je uspešno resetovan", Severity.Success);
            }
            else
            {
                errorMessage = $"Greška: {response.StatusCode}";
                Snackbar.Add($"Greška pri resetovanju XP: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
            Snackbar.Add($"Greška pri resetovanju XP: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
