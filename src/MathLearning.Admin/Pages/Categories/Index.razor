@page "/categories"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Services
@using MathLearning.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@inject AdminDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Kategorije - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" />
    Kategorije
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Upravljajte kategorijama pitanja
</MudText>

<MudPaper Elevation="4" Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Lista Kategorija</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Href="/categories/new"
                   StartIcon="@Icons.Material.Filled.Add">
            Dodaj Kategoriju
        </MudButton>
    </div>

    <MudTable Items="_categories" 
              Hover="true" 
              Loading="@_loading"
              Elevation="0"
              Dense="true">
        <HeaderContent>
            <MudTh>Naziv</MudTh>
            <MudTh>Broj pitanja</MudTh>
            <MudTh Style="text-align: right; width: 200px;">Akcije</MudTh>
        </HeaderContent>

        <RowTemplate Context="category">
            <MudTd DataLabel="Naziv">
                <MudText Typo="Typo.body1">@category.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Broj pitanja">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @(category.QuestionCount > 0 ? category.QuestionCount.ToString() : "0")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Akcije" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/categories/{category.Id}/edit")"
                               title="Izmeni kategoriju"
                               aria-label="Izmeni kategoriju" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="async () => await DeleteCategoryAsync(category)"
                               title="Obrisi kategoriju"
                               aria-label="Obrisi kategoriju" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudAlert Severity="Severity.Info">
                Nema kategorija. Kliknite "Dodaj Kategoriju" da kreirate prvu.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<CategoryViewModel> _categories = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        _loading = true;
        
        var categoryQuestionCounts = await Db.Questions
            .AsNoTracking()
            .GroupBy(q => q.CategoryId)
            .Select(g => new { CategoryId = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.CategoryId, x => x.Count);

        _categories = await Db.Categories
            .AsNoTracking()
            .OrderBy(c => c.Name)
            .Select(c => new CategoryViewModel
            {
                Id = c.Id,
                Name = c.Name,
                QuestionCount = categoryQuestionCounts.GetValueOrDefault(c.Id, 0)
            })
            .ToListAsync();
        
        _loading = false;
    }

    private async Task DeleteCategoryAsync(CategoryViewModel category)
    {
        if (category.QuestionCount > 0)
        {
            var dialogParameters = new DialogParameters
            {
                [nameof(ConfirmDialog.Title)] = "Kategorija ima zavisnosti",
                [nameof(ConfirmDialog.Message)] = DeleteImpactFormatter.BuildCategoryDeleteMessage(category.Name, category.QuestionCount),
                [nameof(ConfirmDialog.ConfirmText)] = "Razumem",
                [nameof(ConfirmDialog.CancelText)] = "Odustani",
                [nameof(ConfirmDialog.ConfirmColor)] = Color.Warning
            };
            await DialogService.ShowAsync<ConfirmDialog>("Potvrda", dialogParameters, new DialogOptions
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Small
            });
            
            Snackbar.Add("Brisanje kategorije je blokirano dok postoje povezana pitanja.", Severity.Warning);
            return;
        }

        var deleteParams = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = "Potvrda brisanja",
            [nameof(ConfirmDialog.Message)] = DeleteImpactFormatter.BuildCategoryDeleteMessage(category.Name, 0),
            [nameof(ConfirmDialog.ConfirmText)] = "Obrisi",
            [nameof(ConfirmDialog.CancelText)] = "Odustani",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };
        var deleteRef = await DialogService.ShowAsync<ConfirmDialog>("Potvrda", deleteParams, new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small
        });
        var deleteResult = await deleteRef.Result;
        if (deleteResult?.Canceled ?? true)
        {
            return;
        }

        try
        {
            var categoryEntity = await Db.Categories.FirstOrDefaultAsync(c => c.Id == category.Id);
            if (categoryEntity != null)
            {
                Db.Categories.Remove(categoryEntity);
                await Db.SaveChangesAsync();
                _categories.Remove(category);
                
                Snackbar.Add($"Kategorija '{category.Name}' je obrisana", Severity.Success);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greška pri brisanju: {ex.Message}", Severity.Error);
        }
    }

    private class CategoryViewModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public int QuestionCount { get; set; }
    }
}
