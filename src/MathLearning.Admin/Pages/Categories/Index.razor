@page "/categories"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Services
@using MathLearning.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@inject AdminDbContext Db
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Kategorije - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" />
    Kategorije
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Upravljajte kategorijama pitanja
</MudText>

<MudPaper Elevation="4" Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Lista Kategorija</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Href="/categories/new"
                   StartIcon="@Icons.Material.Filled.Add">
            Dodaj Kategoriju
        </MudButton>
    </div>

    <MudTable Items="_categories" 
              Hover="true" 
              Loading="@_loading"
              Elevation="0"
              Dense="true">
        <HeaderContent>
            <MudTh>Naziv</MudTh>
            <MudTh Style="text-align: right; width: 200px;">Akcije</MudTh>
        </HeaderContent>

        <RowTemplate Context="category">
            <MudTd DataLabel="Naziv">
                <MudText Typo="Typo.body1">@category.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Akcije" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/categories/{category.Id}/edit")"
                               title="Izmeni kategoriju"
                               aria-label="Izmeni kategoriju" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="async () => await DeleteCategoryAsync(category)"
                               title="Obrisi kategoriju"
                               aria-label="Obrisi kategoriju" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudAlert Severity="Severity.Info">
                Nema kategorija. Kliknite "Dodaj Kategoriju" da kreirate prvu.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<Category> _categories = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        _loading = true;
        _categories = await Db.Categories
            .OrderBy(c => c.Name)
            .ToListAsync();
        _loading = false;
    }

    private async Task DeleteCategoryAsync(Category category)
    {
        var dependentQuestionsCount = await Db.Questions.CountAsync(q => q.CategoryId == category.Id);
        var dialogParameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = dependentQuestionsCount > 0 ? "Kategorija ima zavisnosti" : "Potvrda brisanja",
            [nameof(ConfirmDialog.Message)] = DeleteImpactFormatter.BuildCategoryDeleteMessage(category.Name, dependentQuestionsCount),
            [nameof(ConfirmDialog.ConfirmText)] = dependentQuestionsCount > 0 ? "Razumem" : "Obrisi",
            [nameof(ConfirmDialog.CancelText)] = "Odustani",
            [nameof(ConfirmDialog.ConfirmColor)] = dependentQuestionsCount > 0 ? Color.Warning : Color.Error
        };
        var dialogRef = await DialogService.ShowAsync<ConfirmDialog>("Potvrda", dialogParameters, new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small
        });
        var dialogResult = await dialogRef.Result;
        if (dialogResult?.Canceled ?? true)
        {
            return;
        }

        if (dependentQuestionsCount > 0)
        {
            Snackbar.Add("Brisanje kategorije je blokirano dok postoje povezana pitanja.", Severity.Warning);
            return;
        }

        try
        {
            Db.Categories.Remove(category);
            await Db.SaveChangesAsync();
            _categories.Remove(category);
            
            Snackbar.Add($"Kategorija '{category.Name}' je obrisana", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Greska pri brisanju: {ex.Message}", Severity.Error);
        }
    }
}
