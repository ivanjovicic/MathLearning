@page "/categories/new"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@inject AdminDbContext Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nova Kategorija - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
    Dodaj Novu Kategoriju
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Kreirajte novu kategoriju za pitanja
</MudText>

<MudPaper Class="pa-6" Elevation="4" MaxWidth="600px">
    <MudTextField @bind-Value="CategoryName"
                  Label="Naziv Kategorije *"
                  Variant="Variant.Outlined"
                  Immediate="true"
                  Error="@(!string.IsNullOrEmpty(ErrorMessage))"
                  ErrorText="@ErrorMessage"
                  Class="mb-4" />

    <div class="d-flex gap-2">
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@IsSaving">
            @if (IsSaving)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                <span>Cuvanje...</span>
            }
            else
            {
                <span>Sacuvaj</span>
            }
        </MudButton>

        <MudButton Href="/categories"
                   Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Nazad
        </MudButton>
    </div>
</MudPaper>

@code {
    private string CategoryName { get; set; } = "";
    private string? ErrorMessage { get; set; }
    private bool IsSaving { get; set; } = false;

    private async Task Save()
    {
        ErrorMessage = null;

        if (string.IsNullOrWhiteSpace(CategoryName))
        {
            ErrorMessage = "Naziv kategorije je obavezan";
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            var category = new Category(CategoryName.Trim());
            Db.Categories.Add(category);
            await Db.SaveChangesAsync();

            Snackbar.Add($"Kategorija '{CategoryName}' je uspesno dodata!", Severity.Success);
            Nav.NavigateTo("/categories");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Greska: {ex.Message}";
            IsSaving = false;
        }
    }
}
