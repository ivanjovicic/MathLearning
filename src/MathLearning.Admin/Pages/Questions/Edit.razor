@page "/questions/{Id:int}/edit"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@implements IAsyncDisposable
@using MathLearning.Admin.Data
@using MathLearning.Admin.Models
@using MathLearning.Admin.Services
@using MathLearning.Application.Content
@using MathLearning.Application.DTOs.Questions
@using MathLearning.Application.Services
@using MathLearning.Infrastructure.Services.QuestionAuthoring
@using MathLearning.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json

@inject IDbContextFactory<AdminDbContext> DbFactory
@inject IMathContentSanitizer Sanitizer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<Edit> Logger
@inject IJSRuntime Js
@inject IQuestionAuthoringService QuestionAuthoringService
@inject IMathQuestionAuthoringService MathQuestionAuthoringService
@inject IQuestionVersioningService QuestionVersioningService
@inject AdminQuestionValidationOrchestrator ValidationOrchestrator
@inject IDialogService DialogService

<PageTitle>Izmeni Pitanje #@Id - MathLearning Admin</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />
<MudText Typo="Typo.h3" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
    Pitanje #@Id
</MudText>
@if (!_loading && _question is not null)
{
    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-4">
        @TruncateText(_question.Text, 100)
    </MudText>
}
else
{
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
        Uređivanje math sadržaja sa preview-em i format metadata poljima
    </MudText>
}

<NavigationLock ConfirmExternalNavigation="@HasUnsavedChanges" OnBeforeInternalNavigation="ConfirmNavigationAsync" />

@if (!string.IsNullOrWhiteSpace(_autosaveStatus))
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">@_autosaveStatus</MudText>
}

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <MudAlert Severity="Severity.Error">@_loadError</MudAlert>
}
else if (_question is null)
{
    <MudAlert Severity="Severity.Error">Pitanje nije pronađeno.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-3">
        Poslednja izmena:
        @_question.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        @if (!string.IsNullOrWhiteSpace(_question.UpdatedBy))
        {
            <span>od @_question.UpdatedBy</span>
        }
    </MudAlert>

    <div class="d-flex align-center gap-2 mb-3 flex-wrap">
        <MudAlert Severity="@GetValidationAlertSeverity()" Dense="true" Variant="Variant.Outlined" Class="mb-0 flex-grow-1">
            Status: <strong>@GetPublishStateLabel(_question.PublishState)</strong>
            @if (!string.IsNullOrWhiteSpace(_currentDraftValidationStatus))
            {
                <span> | Validacija: <strong>@GetValidationStatusLabel(_currentDraftValidationStatus)</strong></span>
            }
        </MudAlert>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="RunValidationAsync"
                   Disabled="@(_isValidating || IsSaving)"
                   Size="Size.Small">
            @if (_isValidating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
            }
            Validiraj
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="RevalidatePersistedDraftAsync"
                   Disabled="@(_isRevalidating || IsSaving || _question.CurrentDraftId is null)"
                   Size="Size.Small">
            @if (_isRevalidating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
            }
            Revalidiraj draft
        </MudButton>
        @if (_question.PublishState is not QuestionPublishStates.Published)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Publish"
                       OnClick="PublishAsync"
                       Disabled="@(!CanPublish || IsSaving)"
                       Size="Size.Small">
                Objavi
            </MudButton>
        }
    </div>

    <ValidationDetailPanel Result="@_validationResult" />

    @if (_latestValidation is not null)
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <div class="d-flex align-center justify-space-between gap-2 mb-3 flex-wrap">
                <div>
                    <MudText Typo="Typo.h6">Poslednja validacija</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @FormatUtcDate(_latestValidation.ValidatedAtUtc) | @GetValidationStatusLabel(_latestValidation.Status)
                    </MudText>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <MudChip T="string" Variant="Variant.Outlined" Color="@GetValidationChipColor(_latestValidation.Status)" Size="Size.Small">
                        @GetValidationStatusLabel(_latestValidation.Status)
                    </MudChip>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@(_latestValidation.HasErrors ? Color.Error : Color.Success)" Size="Size.Small">
                        Greške: @_latestValidation.Issues.Count(x => string.Equals(x.Severity, ValidationIssueSeverities.Error, StringComparison.OrdinalIgnoreCase))
                    </MudChip>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@(_latestValidation.HasWarnings ? Color.Warning : Color.Success)" Size="Size.Small">
                        Upozorenja: @_latestValidation.Issues.Count(x => string.Equals(x.Severity, ValidationIssueSeverities.Warning, StringComparison.OrdinalIgnoreCase))
                    </MudChip>
                </div>
            </div>

            @if (_latestValidation.Issues.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined">
                    Nema otvorenih validacionih problema na poslednjem snimljenom draftu.
                </MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var issue in _latestValidation.Issues.Take(6))
                    {
                        <MudListItem T="string" Icon="@GetValidationIssueIcon(issue.Severity)">
                            <div>
                                <strong>@GetValidationIssueSeverityLabel(issue.Severity):</strong> @issue.Message
                                @if (!string.IsNullOrWhiteSpace(issue.FieldPath))
                                {
                                    <div class="text-muted">@issue.FieldPath</div>
                                }
                            </div>
                        </MudListItem>
                    }
                </MudList>

                @if (_latestValidation.Issues.Count > 6)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Prikazano prvih 6 od @_latestValidation.Issues.Count problema.
                    </MudText>
                }
            }
        </MudPaper>
    }

    @if (_versionHistory.Count > 0)
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <div class="d-flex align-center justify-space-between gap-2 mb-3 flex-wrap">
                <div>
                    <MudText Typo="Typo.h6">Istorija verzija</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Poslednje objave i razlozi promena za ovo pitanje.
                    </MudText>
                </div>
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                    @_versionHistory.Count verzija
                </MudChip>
            </div>

            <MudTable Items="@_versionHistory" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Verzija</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Audit</MudTh>
                    <MudTh>Autor/Editor</MudTh>
                    <MudTh>Kreirano</MudTh>
                    <MudTh>Objavljeno</MudTh>
                    <MudTh>Napomena</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Verzija">v@context.VersionNumber</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Color="@GetPublishStateColor(context.PublishState)"
                                 Size="Size.Small">
                            @GetPublishStateLabel(context.PublishState)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Audit">
                        <div class="d-flex flex-column gap-1">
                            <MudChip T="string"
                                     Variant="Variant.Outlined"
                                     Color="@GetVersionAuditColor(context)"
                                     Size="Size.Small">
                                @GetVersionAuditLabel(context)
                            </MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @GetVersionAuditHint(context)
                            </MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Autor/Editor">@GetVersionActorLabel(context)</MudTd>
                    <MudTd DataLabel="Kreirano">@FormatUtcDate(context.CreatedAtUtc)</MudTd>
                    <MudTd DataLabel="Objavljeno">@FormatUtcDate(context.PublishedAtUtc)</MudTd>
                    <MudTd DataLabel="Napomena">@GetChangeReasonLabel(context.ChangeReason)</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <QuestionEditor Model="@Model"
                    Categories="@Categories"
                    Subtopics="@Subtopics"
                    IsSaving="@IsSaving"
                    SaveButtonText="Sačuvaj izmene"
                    ValidationErrors="@ValidationErrors"
                    OnSave="SaveAsync" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private QuestionEditorModel Model = new();
    private QuestionEditorHelper? _editorHelper;
    private Question? _question;
    private List<Category> Categories { get; set; } = [];
    private List<Subtopic> Subtopics { get; set; } = [];
    private bool _loading = true;
    private bool IsSaving { get; set; }

    private List<BreadcrumbItem> _breadcrumbs =>
    [
        new BreadcrumbItem("Pitanja", href: "/questions"),
        new BreadcrumbItem($"#{Id}", href: null, disabled: true)
    ];

    private static string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        return text.Length <= maxLength ? text : text[..maxLength] + "…";
    }
    private List<string> ValidationErrors { get; set; } = [];
    private string? _loadError;
    private string? _currentDraftValidationStatus;
    private string _initialSnapshot = string.Empty;
    private IJSObjectReference? _autosaveModule;
    private System.Timers.Timer? _autosaveTimer;
    private string _lastAutosavedSnapshot = string.Empty;
    private string? _autosaveStatus;
    private ValidateQuestionResponse? _validationResult;
    private bool _isValidating;
    private bool _isRevalidating;
    private IReadOnlyList<QuestionVersionHistoryItemDto> _versionHistory = [];
    private QuestionValidationHistoryDto? _latestValidation;
    private bool CanPublish =>
        _validationResult?.Summary.CanPublish == true ||
        _currentDraftValidationStatus is QuestionValidationStatuses.Passed or QuestionValidationStatuses.PassedWithWarnings;
    private bool HasUnsavedChanges =>
        !_loading &&
        !IsSaving &&
        !string.Equals(_initialSnapshot, _editorHelper?.CreateModelSnapshot(Model), StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _editorHelper = new QuestionEditorHelper(Sanitizer);

            await using var db = await DbFactory.CreateDbContextAsync();

            Categories = await db.Categories
                .AsNoTracking()
                .OrderBy(c => c.Name)
                .ToListAsync();

            Subtopics = await db.Subtopics
                .AsNoTracking()
                .Include(x => x.Topic)
                .OrderBy(x => x.Topic!.Name)
                .ThenBy(x => x.Name)
                .ToListAsync();

            _question = await db.Questions
                .AsNoTracking()
                .Include(x => x.Options)
                .Include(x => x.Steps)
                .FirstOrDefaultAsync(x => x.Id == Id);

            if (_question is not null && _editorHelper is not null)
            {
                _editorHelper.MapQuestionToModel(_question, Model);
                if (_question.CurrentDraftId.HasValue)
                {
                    _currentDraftValidationStatus = await db.QuestionDrafts
                        .AsNoTracking()
                        .Where(x => x.Id == _question.CurrentDraftId.Value)
                        .Select(x => x.ValidationStatus)
                        .FirstOrDefaultAsync();
                }
            }

            await LoadVersionHistoryAsync();
            await LoadLatestValidationAsync();

            MarkSnapshot();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing edit question page {QuestionId}", Id);
            _loadError = "Greška pri učitavanju pitanja za izmenu. Pokušajte ponovo za nekoliko trenutaka.";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var draftKey = $"question-editor-draft-{Id}";

        try
        {
            _autosaveModule = await Js.InvokeAsync<IJSObjectReference>("import", "./autosave.js");

            var draft = await _autosaveModule.InvokeAsync<string?>("loadDraft", draftKey);
            if (!string.IsNullOrEmpty(draft))
            {
                var shouldRestore = await DialogService.ShowMessageBox(
                    "Nesačuvan draft",
                    "Pronađen je nesačuvan draft. Da li želite da ga učitate?",
                    yesText: "Učitaj draft",
                    noText: "Odbaci");
                if (shouldRestore == true)
                {
                    try
                    {
                        var restored = JsonSerializer.Deserialize<QuestionEditorModel>(draft);
                        if (restored is not null)
                        {
                            Model = restored;
                            MarkSnapshot();
                            _lastAutosavedSnapshot = _initialSnapshot;
                            _autosaveStatus = $"Draft učitan u {DateTime.Now:HH:mm:ss}.";
                            StateHasChanged();
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Failed to restore autosave draft for question {QuestionId}", Id);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to initialize autosave module for question {QuestionId}", Id);
        }

        StartAutosaveTimer(draftKey);
    }

    private void StartAutosaveTimer(string draftKey)
    {
        _autosaveTimer = new System.Timers.Timer(TimeSpan.FromSeconds(8));
        _autosaveTimer.Elapsed += (_, _) => InvokeAsync(() => AutosaveAsync(draftKey));
        _autosaveTimer.AutoReset = true;
        _autosaveTimer.Start();
    }

    private async Task AutosaveAsync(string draftKey)
    {
        if (IsSaving || _autosaveModule is null || _editorHelper is null) return;

        var currentSnapshot = _editorHelper.CreateModelSnapshot(Model);
        if (string.Equals(currentSnapshot, _lastAutosavedSnapshot, StringComparison.Ordinal)) return;

        try
        {
            await _autosaveModule.InvokeVoidAsync("saveDraft", draftKey, currentSnapshot);
            _lastAutosavedSnapshot = currentSnapshot;
            _autosaveStatus = $"Automatski sačuvano u {DateTime.Now:HH:mm:ss}.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Autosave failed for question {QuestionId}", Id);
            Snackbar.Add("Auto-čuvanje nije uspelo.", Severity.Warning);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_autosaveTimer is not null)
        {
            _autosaveTimer.Stop();
            _autosaveTimer.Dispose();
        }

        if (_autosaveModule is not null)
        {
            try { await _autosaveModule.DisposeAsync(); }
            catch { /* Ignore JS disposal errors */ }
        }
    }

    private async Task SaveAsync()
    {
        if (_editorHelper is null || _question is null)
        {
            return;
        }

        ValidationErrors = _editorHelper.ValidateModel(Model);
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            try
            {
                var question = await db.Questions
                    .Include(x => x.Options)
                    .Include(x => x.Steps)
                    .FirstOrDefaultAsync(x => x.Id == Id);
                if (question is null)
                {
                    ValidationErrors = ["Pitanje nije pronađeno. Osvežite listu i pokušajte ponovo."];
                    return;
                }

                var request = _editorHelper.ToAuthoringRequest(Model, _question.Id);
                var wasPublished = string.Equals(question.PublishState, QuestionPublishStates.Published, StringComparison.Ordinal);
                await QuestionAuthoringService.UpdateQuestionAsync(db, question, request, "admin_ui", CancellationToken.None);
                if (wasPublished)
                {
                    question.SetPublishState(QuestionPublishStates.Draft, "admin_ui", null);
                }
                var draftSaveResult = await MathQuestionAuthoringService.SaveDraftAsync(
                    new SaveQuestionDraftRequest(request, "admin_ui_save"),
                    "admin_ui",
                    CancellationToken.None);
                await tx.CommitAsync();
                _question = question;
                _currentDraftValidationStatus = draftSaveResult.Validation.Summary.Status;
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }

            Snackbar.Add("Pitanje je uspešno izmenjeno.", Severity.Success);
            MarkSnapshot();

            var draftKey = $"question-editor-draft-{Id}";
            if (_autosaveModule is not null)
            {
                try { await _autosaveModule.InvokeVoidAsync("clearDraft", draftKey); }
                catch { /* Ignore */ }
            }

            Nav.NavigateTo("/questions");
        }
        catch (DbUpdateConcurrencyException)
        {
            ValidationErrors = ["Pitanje je izmenjeno od strane drugog korisnika. Osvežite stranicu i ponovite izmene."];
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Database error saving question {QuestionId}", Id);
            ValidationErrors = ["Greška pri čuvanju u bazu podataka. Pokušajte ponovo."];
        }
        catch (FluentValidation.ValidationException ex)
        {
            Logger.LogWarning(ex, "Validation error saving question {QuestionId}", Id);
            ValidationErrors = ex.Errors
                .Select(x => x.ErrorMessage)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving question {QuestionId}", Id);
            ValidationErrors = ["Neočekivana greška. Kontaktirajte administratora."];
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void MarkSnapshot()
    {
        _initialSnapshot = _editorHelper?.CreateModelSnapshot(Model) ?? string.Empty;
    }

    private async Task ConfirmNavigationAsync(LocationChangingContext context)
    {
        if (!HasUnsavedChanges)
        {
            return;
        }

        var result = await DialogService.ShowMessageBox(
            "Nesačuvane izmene",
            "Imate nesačuvane izmene. Da li sigurno želite da napustite stranicu?",
            yesText: "Napusti",
            noText: "Ostani");
        if (result != true)
        {
            context.PreventNavigation();
        }
    }

    private async Task LoadVersionHistoryAsync()
    {
        _versionHistory = await QuestionVersioningService.GetVersionsAsync(Id, CancellationToken.None);
    }

    private async Task LoadLatestValidationAsync()
    {
        _latestValidation = await MathQuestionAuthoringService.GetValidationAsync(Id, CancellationToken.None);
        if (_latestValidation is not null)
        {
            _currentDraftValidationStatus = _latestValidation.Status;
        }
    }

    private async Task RunValidationAsync()
    {
        if (_editorHelper is null) return;
        _isValidating = true;
        _validationResult = null;
        StateHasChanged();
        try
        {
            var request = _editorHelper.ToAuthoringRequest(Model, Id);
            _validationResult = await ValidationOrchestrator.ValidateAsync(request);
            _currentDraftValidationStatus = _validationResult.Summary.Status;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Validation failed for question {QuestionId}", Id);
            Snackbar.Add("Greška pri validaciji pitanja.", Severity.Error);
        }
        finally
        {
            _isValidating = false;
            StateHasChanged();
        }
    }

    private async Task RevalidatePersistedDraftAsync()
    {
        if (_question?.CurrentDraftId is null)
        {
            Snackbar.Add("Nema drafta za revalidaciju.", Severity.Info);
            return;
        }

        _isRevalidating = true;
        StateHasChanged();
        try
        {
            _latestValidation = await MathQuestionAuthoringService.RevalidateAsync(Id, "admin_ui", CancellationToken.None);
            _currentDraftValidationStatus = _latestValidation.Status;
            Snackbar.Add("Draft je ponovo validiran.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to revalidate question draft {QuestionId}", Id);
            Snackbar.Add("Greška pri revalidaciji drafta.", Severity.Error);
        }
        finally
        {
            _isRevalidating = false;
            StateHasChanged();
        }
    }

    private async Task PublishAsync()
    {
        if (_question is null || _editorHelper is null) return;

        ValidationErrors = _editorHelper.ValidateModel(Model);
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        var confirm = await DialogService.ShowMessageBox(
            "Objavljivanje pitanja",
            "Da li sigurno želite da objavite ovo pitanje? Postaje vidljivo studentima.",
            yesText: "Objavi",
            noText: "Otkaži");
        if (confirm != true) return;

        IsSaving = true;
        StateHasChanged();
        try
        {
            var request = _editorHelper.ToAuthoringRequest(Model, Id);
            var draftResult = await MathQuestionAuthoringService.SaveDraftAsync(
                new SaveQuestionDraftRequest(request, "admin_ui_publish"),
                "admin_ui",
                CancellationToken.None);
            var publishResult = await MathQuestionAuthoringService.PublishAsync(
                new PublishQuestionRequest(draftResult.DraftId, "admin_ui_publish"),
                "admin_ui",
                CancellationToken.None);

            if (!publishResult.Published)
            {
                ValidationErrors = publishResult.ValidationSummary.Issues
                    .Select(x => x.Message)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct()
                    .ToList();
                Snackbar.Add("Pitanje nije spremno za objavljivanje.", Severity.Warning);
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            _question = await db.Questions
                .AsNoTracking()
                .Include(x => x.Options)
                .Include(x => x.Steps)
                .FirstOrDefaultAsync(x => x.Id == Id);
            _currentDraftValidationStatus = publishResult.ValidationSummary.Status;
            await LoadLatestValidationAsync();
            await LoadVersionHistoryAsync();
            Snackbar.Add("Pitanje je uspešno objavljeno.", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to publish question {QuestionId}", Id);
            Snackbar.Add("Greška pri objavljivanju pitanja.", Severity.Error);
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private Severity GetValidationAlertSeverity()
        => _currentDraftValidationStatus switch
        {
            QuestionValidationStatuses.Failed => Severity.Error,
            QuestionValidationStatuses.PassedWithWarnings => Severity.Warning,
            QuestionValidationStatuses.Passed => Severity.Success,
            _ => Severity.Info
        };

    private static string GetPublishStateLabel(string publishState) => publishState switch
    {
        QuestionPublishStates.Published => "Objavljeno",
        QuestionPublishStates.Validated => "Validirano",
        QuestionPublishStates.Archived => "Arhivirano",
        _ => "Draft"
    };

    private static Color GetPublishStateColor(string publishState) => publishState switch
    {
        QuestionPublishStates.Published => Color.Success,
        QuestionPublishStates.Validated => Color.Info,
        QuestionPublishStates.Archived => Color.Secondary,
        _ => Color.Warning
    };

    private static string GetValidationStatusLabel(string validationStatus) => validationStatus switch
    {
        QuestionValidationStatuses.Passed => "Bez grešaka",
        QuestionValidationStatuses.PassedWithWarnings => "Upozorenja",
        QuestionValidationStatuses.Failed => "Problematično",
        _ => "Na čekanju"
    };

    private static Color GetValidationChipColor(string validationStatus) => validationStatus switch
    {
        QuestionValidationStatuses.Passed => Color.Success,
        QuestionValidationStatuses.PassedWithWarnings => Color.Warning,
        QuestionValidationStatuses.Failed => Color.Error,
        _ => Color.Info
    };

    private static string FormatUtcDate(DateTime? value)
        => value?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Nije objavljeno";

    private static string GetChangeReasonLabel(string? changeReason)
        => string.IsNullOrWhiteSpace(changeReason) ? "Bez napomene" : changeReason;

    private static string GetVersionActorLabel(QuestionVersionHistoryItemDto version)
    {
        if (!string.IsNullOrWhiteSpace(version.EditorUserId))
        {
            return version.EditorUserId!;
        }

        if (!string.IsNullOrWhiteSpace(version.AuthorUserId))
        {
            return version.AuthorUserId!;
        }

        return "Sistem";
    }

    private static Color GetVersionAuditColor(QuestionVersionHistoryItemDto version)
        => version.PreviousVersionId.HasValue ? Color.Info : Color.Success;

    private static string GetVersionAuditLabel(QuestionVersionHistoryItemDto version)
        => version.PreviousVersionId.HasValue ? "Iteracija" : "Prva objava";

    private static string GetVersionAuditHint(QuestionVersionHistoryItemDto version)
    {
        if (version.PreviousVersionId.HasValue)
        {
            return $"Nastavlja verzionisanje nakon v{Math.Max(1, version.VersionNumber - 1)}.";
        }

        return "Prvi objavljeni snapshot ovog pitanja.";
    }

    private static string GetValidationIssueIcon(string severity) => severity switch
    {
        ValidationIssueSeverities.Error => Icons.Material.Filled.ErrorOutline,
        ValidationIssueSeverities.Warning => Icons.Material.Filled.WarningAmber,
        _ => Icons.Material.Filled.Info
    };

    private static string GetValidationIssueSeverityLabel(string severity) => severity switch
    {
        ValidationIssueSeverities.Error => "Greška",
        ValidationIssueSeverities.Warning => "Upozorenje",
        _ => "Info"
    };
}
