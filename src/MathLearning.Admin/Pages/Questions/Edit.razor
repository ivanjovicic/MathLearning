@page "/questions/{Id:int}/edit"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@implements IAsyncDisposable
@using MathLearning.Admin.Data
@using MathLearning.Admin.Models
@using MathLearning.Application.Content
@using MathLearning.Infrastructure.Services.QuestionAuthoring
@using MathLearning.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json

@inject AdminDbContext Db
@inject IMathContentSanitizer Sanitizer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<Edit> Logger
@inject IJSRuntime Js
@inject IQuestionAuthoringService QuestionAuthoringService

<PageTitle>Izmeni Pitanje - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
    Izmeni Pitanje
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Uređivanje math sadržaja sa preview-em i format metadata poljima
</MudText>

<NavigationLock ConfirmExternalNavigation="@HasUnsavedChanges" OnBeforeInternalNavigation="ConfirmNavigationAsync" />

@if (!string.IsNullOrWhiteSpace(_autosaveStatus))
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">@_autosaveStatus</MudText>
}

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <MudAlert Severity="Severity.Error">@_loadError</MudAlert>
}
else if (_question is null)
{
    <MudAlert Severity="Severity.Error">Pitanje nije pronađeno.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-3">
        Poslednja izmena:
        @_question.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        @if (!string.IsNullOrWhiteSpace(_question.UpdatedBy))
        {
            <span>od @_question.UpdatedBy</span>
        }
    </MudAlert>

    <QuestionEditor Model="@Model"
                    Categories="@Categories"
                    Subtopics="@Subtopics"
                    IsSaving="@IsSaving"
                    SaveButtonText="Sačuvaj izmene"
                    ValidationErrors="@ValidationErrors"
                    OnSave="SaveAsync" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private QuestionEditorModel Model = new();
    private QuestionEditorHelper? _editorHelper;
    private Question? _question;
    private List<Category> Categories { get; set; } = [];
    private List<Subtopic> Subtopics { get; set; } = [];
    private bool _loading = true;
    private bool IsSaving { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private string? _loadError;
    private string _initialSnapshot = string.Empty;
    private IJSObjectReference? _autosaveModule;
    private System.Timers.Timer? _autosaveTimer;
    private string _lastAutosavedSnapshot = string.Empty;
    private string? _autosaveStatus;
    private bool HasUnsavedChanges =>
        !_loading &&
        !IsSaving &&
        !string.Equals(_initialSnapshot, _editorHelper?.CreateModelSnapshot(Model), StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _editorHelper = new QuestionEditorHelper(Sanitizer);

            Categories = await Db.Categories
                .AsNoTracking()
                .OrderBy(c => c.Name)
                .ToListAsync();

            Subtopics = await Db.Subtopics
                .AsNoTracking()
                .Include(x => x.Topic)
                .OrderBy(x => x.Topic!.Name)
                .ThenBy(x => x.Name)
                .ToListAsync();

            _question = await Db.Questions
                .Include(x => x.Options)
                .Include(x => x.Steps)
                .FirstOrDefaultAsync(x => x.Id == Id);

            if (_question is not null && _editorHelper is not null)
            {
                _editorHelper.MapQuestionToModel(_question, Model);
            }

            MarkSnapshot();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing edit question page {QuestionId}", Id);
            _loadError = "Greška pri učitavanju pitanja za izmenu. Pokušajte ponovo za nekoliko trenutaka.";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var draftKey = $"question-editor-draft-{Id}";

        try
        {
            _autosaveModule = await Js.InvokeAsync<IJSObjectReference>("import", "./autosave.js");

            var draft = await _autosaveModule.InvokeAsync<string?>("loadDraft", draftKey);
            if (!string.IsNullOrEmpty(draft))
            {
                var shouldRestore = await Js.InvokeAsync<bool>("confirm", "Pronađen je nesačuvan draft. Da li želite da ga učitate?");
                if (shouldRestore)
                {
                    try
                    {
                        var restored = JsonSerializer.Deserialize<QuestionEditorModel>(draft);
                        if (restored is not null)
                        {
                            Model = restored;
                            MarkSnapshot();
                            _lastAutosavedSnapshot = _initialSnapshot;
                            _autosaveStatus = $"Draft učitan u {DateTime.Now:HH:mm:ss}.";
                            StateHasChanged();
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Failed to restore autosave draft for question {QuestionId}", Id);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to initialize autosave module for question {QuestionId}", Id);
        }

        StartAutosaveTimer(draftKey);
    }

    private void StartAutosaveTimer(string draftKey)
    {
        _autosaveTimer = new System.Timers.Timer(TimeSpan.FromSeconds(8));
        _autosaveTimer.Elapsed += (_, _) => InvokeAsync(() => AutosaveAsync(draftKey));
        _autosaveTimer.AutoReset = true;
        _autosaveTimer.Start();
    }

    private async Task AutosaveAsync(string draftKey)
    {
        if (IsSaving || _autosaveModule is null || _editorHelper is null) return;

        var currentSnapshot = _editorHelper.CreateModelSnapshot(Model);
        if (string.Equals(currentSnapshot, _lastAutosavedSnapshot, StringComparison.Ordinal)) return;

        try
        {
            await _autosaveModule.InvokeVoidAsync("saveDraft", draftKey, currentSnapshot);
            _lastAutosavedSnapshot = currentSnapshot;
            _autosaveStatus = $"Automatski sačuvano u {DateTime.Now:HH:mm:ss}.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Autosave failed for question {QuestionId}", Id);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_autosaveTimer is not null)
        {
            _autosaveTimer.Stop();
            _autosaveTimer.Dispose();
        }

        if (_autosaveModule is not null)
        {
            try { await _autosaveModule.DisposeAsync(); }
            catch { /* Ignore JS disposal errors */ }
        }
    }

    private async Task SaveAsync()
    {
        if (_editorHelper is null || _question is null)
        {
            return;
        }

        ValidationErrors = _editorHelper.ValidateModel(Model);
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            await using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                var request = _editorHelper.ToAuthoringRequest(Model, _question.Id);
                await QuestionAuthoringService.UpdateQuestionAsync(Db, _question, request, "admin_ui", CancellationToken.None);
                await tx.CommitAsync();
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }

            Snackbar.Add("Pitanje je uspešno izmenjeno.", Severity.Success);
            MarkSnapshot();

            var draftKey = $"question-editor-draft-{Id}";
            if (_autosaveModule is not null)
            {
                try { await _autosaveModule.InvokeVoidAsync("clearDraft", draftKey); }
                catch { /* Ignore */ }
            }

            Nav.NavigateTo("/questions");
        }
        catch (DbUpdateConcurrencyException)
        {
            ValidationErrors = ["Pitanje je izmenjeno od strane drugog korisnika. Osvežite stranicu i ponovite izmene."];
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Database error saving question {QuestionId}", Id);
            ValidationErrors = ["Greška pri čuvanju u bazu podataka. Pokušajte ponovo."];
        }
        catch (FluentValidation.ValidationException ex)
        {
            Logger.LogWarning(ex, "Validation error saving question {QuestionId}", Id);
            ValidationErrors = ex.Errors
                .Select(x => x.ErrorMessage)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving question {QuestionId}", Id);
            ValidationErrors = ["Neočekivana greška. Kontaktirajte administratora."];
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void MarkSnapshot()
    {
        _initialSnapshot = _editorHelper?.CreateModelSnapshot(Model) ?? string.Empty;
    }

    private async Task ConfirmNavigationAsync(LocationChangingContext context)
    {
        if (!HasUnsavedChanges)
        {
            return;
        }

        var shouldLeave = await Js.InvokeAsync<bool>("confirm", "Imate nesacuvane izmene. Da li sigurno zelite da napustite stranicu?");
        if (!shouldLeave)
        {
            context.PreventNavigation();
        }
    }
}
