@page "/questions/{Id:int}/edit"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Models
@using MathLearning.Application.Content
@using MathLearning.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json

@inject AdminDbContext Db
@inject IMathContentSanitizer Sanitizer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<Edit> Logger
@inject IJSRuntime Js

<PageTitle>Izmeni Pitanje - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
    Izmeni Pitanje
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Uređivanje math sadržaja sa preview-em i format metadata poljima
</MudText>

<NavigationLock ConfirmExternalNavigation="@HasUnsavedChanges" OnBeforeInternalNavigation="ConfirmNavigationAsync" />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_question is null)
{
    <MudAlert Severity="Severity.Error">Pitanje nije pronađeno.</MudAlert>
}
else
{
    <QuestionEditor Model="@Model"
                    Categories="@Categories"
                    Subtopics="@Subtopics"
                    IsSaving="@IsSaving"
                    SaveButtonText="Sačuvaj izmene"
                    ValidationErrors="@ValidationErrors"
                    OnSave="SaveAsync" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private readonly QuestionEditorModel Model = new();
    private QuestionEditorHelper? _editorHelper;
    private Question? _question;
    private List<Category> Categories { get; set; } = [];
    private List<Subtopic> Subtopics { get; set; } = [];
    private bool _loading = true;
    private bool IsSaving { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private string _initialSnapshot = string.Empty;
    private bool HasUnsavedChanges =>
        !_loading &&
        !IsSaving &&
        !string.Equals(_initialSnapshot, _editorHelper?.CreateModelSnapshot(Model), StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        _editorHelper = new QuestionEditorHelper(Sanitizer);

        Categories = await Db.Categories
            .AsNoTracking()
            .OrderBy(c => c.Name)
            .ToListAsync();

        Subtopics = await Db.Subtopics
            .AsNoTracking()
            .Include(x => x.Topic)
            .OrderBy(x => x.Topic!.Name)
            .ThenBy(x => x.Name)
            .ToListAsync();

        _question = await Db.Questions
            .Include(x => x.Options)
            .Include(x => x.Steps)
            .FirstOrDefaultAsync(x => x.Id == Id);

        if (_question is not null && _editorHelper is not null)
        {
            _editorHelper.MapQuestionToModel(_question, Model);
        }

        _loading = false;
        MarkSnapshot();
    }

    private async Task SaveAsync()
    {
        if (_editorHelper is null || _question is null)
        {
            return;
        }

        ValidationErrors = _editorHelper.ValidateModel(Model);
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            await using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                if (_question.Text != Model.Text)
                {
                    _question.SetText(_editorHelper.Sanitize(Model.Text, Model.TextFormat));
                }

                _editorHelper.ApplyQuestionFields(_question, Model);
                _question.ReplaceOptions(_editorHelper.BuildOptions(Model));

                if (_question.Steps.Count > 0)
                {
                    Db.QuestionSteps.RemoveRange(_question.Steps);
                }

                _question.ReplaceSteps([]);
                await Db.SaveChangesAsync();

                var steps = _editorHelper.BuildSteps(_question.Id, Model);
                if (steps.Count > 0)
                {
                    _question.ReplaceSteps(steps);
                }

                await Db.SaveChangesAsync();
                await tx.CommitAsync();
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }

            Snackbar.Add("Pitanje je uspešno izmenjeno.", Severity.Success);
            MarkSnapshot();
            Nav.NavigateTo("/questions");
        }
        catch (DbUpdateConcurrencyException)
        {
            ValidationErrors = ["Pitanje je izmenjeno od strane drugog korisnika. Osvežite stranicu i ponovite izmene."];
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Database error saving question {QuestionId}", Id);
            ValidationErrors = ["Greška pri čuvanju u bazu podataka. Pokušajte ponovo."];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving question {QuestionId}", Id);
            ValidationErrors = ["Neočekivana greška. Kontaktirajte administratora."];
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void MarkSnapshot()
    {
        _initialSnapshot = _editorHelper?.CreateModelSnapshot(Model) ?? string.Empty;
    }

    private async Task ConfirmNavigationAsync(LocationChangingContext context)
    {
        if (!HasUnsavedChanges)
        {
            return;
        }

        var shouldLeave = await Js.InvokeAsync<bool>("confirm", "Imate nesacuvane izmene. Da li sigurno zelite da napustite stranicu?");
        if (!shouldLeave)
        {
            context.PreventNavigation();
        }
    }
}
