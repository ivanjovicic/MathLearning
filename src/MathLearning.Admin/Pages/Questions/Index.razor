@page "/questions"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Services
@using MathLearning.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MathLearning.Admin.Components.Dialogs
@using MudBlazor
@inject IDbContextFactory<AdminDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<Index> Logger

<PageTitle>Pitanja - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Quiz" Class="mr-2" />
    Pitanja
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Upravljajte pitanjima i odgovorima
</MudText>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
}

<MudPaper Elevation="4" Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchText" 
                          Placeholder="Pretraži pitanja..." 
                          Variant="Variant.Outlined"
                          DebounceInterval="400"
                          TextChanged="OnSearchTextChangedAsync"
                          Clearable="true"
                          OnClearButtonClick="ResetSearchAndReloadAsync" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_selectedCategoryId" 
                       Label="Kategorija" 
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var category in _categories)
                {
                    <MudSelectItem Value="@category.Id">@category.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_selectedSubtopicId"
                       Label="Podtema"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var subtopic in _subtopics)
                {
                    <MudSelectItem Value="@subtopic.Id">@subtopic.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedType" 
                       Label="Tip pitanja" 
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="string" Value="@("multiple_choice")">Višestruki izbor</MudSelectItem>
                <MudSelectItem T="string" Value="@("open_answer")">Otvoren odgovor</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="int?" @bind-Value="_selectedDifficulty"
                       Label="Težina"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @for (var difficulty = 1; difficulty <= 5; difficulty++)
                {
                    <MudSelectItem T="int?" Value="@((int?)difficulty)">@difficulty</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedPublishState"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var status in _publishStates)
                {
                    <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedAttentionFilter"
                       Label="Pažnja"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="string" Value="@AttentionFilterProblematic">Problematična</MudSelectItem>
                <MudSelectItem T="string" Value="@AttentionFilterWarnings">Sa upozorenjima</MudSelectItem>
                <MudSelectItem T="string" Value="@AttentionFilterReady">Spremna za objavu</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedValidationStatus"
                       Label="Validacija"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="string" Value="@QuestionValidationStatuses.Passed">Bez grešaka</MudSelectItem>
                <MudSelectItem T="string" Value="@QuestionValidationStatuses.PassedWithWarnings">Upozorenja</MudSelectItem>
                <MudSelectItem T="string" Value="@QuestionValidationStatuses.Failed">Problematično</MudSelectItem>
                <MudSelectItem T="string" Value="@ValidationStatusPending">Na čekanju</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_selectedAuthor"
                          Label="Autor / izmenio"
                          Placeholder="npr. admin_ui"
                          Variant="Variant.Outlined"
                          Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker Label="Izmenjeno nakon"
                           Variant="Variant.Outlined"
                           Date="@_updatedAfterDate"
                           DateChanged="OnUpdatedAfterDateChangedAsync"
                           Clearable="true"
                           Editable="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker Label="Izmenjeno pre"
                           Variant="Variant.Outlined"
                           Date="@_updatedBeforeDate"
                           DateChanged="OnUpdatedBeforeDateChangedAsync"
                           Clearable="true"
                           Editable="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudButton OnClick="LoadQuestionsAsync" 
                       Color="Color.Primary" 
                       Variant="Variant.Filled"
                       FullWidth="true">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                Pretraži
            </MudButton>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudButton OnClick="ResetSearchAndReloadAsync"
                       Color="Color.Default"
                       Variant="Variant.Outlined"
                       FullWidth="true">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Class="mr-2" />
                Očisti filtere (@ActiveFilterCount)
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="4" Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Lista Pitanja</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Href="/questions/new"
                   StartIcon="@Icons.Material.Filled.Add">
            Dodaj Pitanje
        </MudButton>
    </div>

    @if (ActiveFilterCount > 0)
    {
        <MudChipSet T="string" Class="mb-4 gap-2">
            @foreach (var filter in ActiveFilterLabels)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Outlined"
                         Color="Color.Info"
                         Class="cursor-pointer"
                         @onclick="async () => await RemoveFilterAsync(filter.Key)">
                    <span class="d-inline-flex align-center gap-1">
                        <span>@filter.Label</span>
                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                    </span>
                </MudChip>
            }
        </MudChipSet>
    }

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_questions.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            @if (ActiveFilterCount > 0)
            {
                <div class="d-flex flex-column gap-2">
                    <span>Nema pitanja za izabrane filtere. Pokušajte sa širim kriterijumima.</span>
                    <div>
                        <MudButton OnClick="ResetSearchAndReloadAsync"
                                   Variant="Variant.Text"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.FilterAltOff">
                            Očisti filtere
                        </MudButton>
                    </div>
                </div>
            }
            else
            {
                <span>Nema pitanja sa izabranim kriterijumima. Kliknite "Dodaj Pitanje" da kreirate prvo.</span>
            }
        </MudAlert>
    }
    else
    {
        <MudTable Items="_questions" 
                  Hover="true" 
                  Dense="true"
                  Elevation="0">
            <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.Id)">ID</MudTableSortLabel></MudTh>
                <MudTh>Tekst</MudTh>
                <MudTh>Tip</MudTh>
                <MudTh>Kategorija</MudTh>
                <MudTh>Podtema</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.PublishState)">Stanje</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.Difficulty)">Tezina</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.UpdatedAt)" InitialDirection="SortDirection.Descending">Poslednja izmena</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right; width: 140px;">Akcije</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="Tekst">
                    <div class="question-list-preview">
                        <MathPreview Content="@context.Text"
                                     Format="@context.TextFormat"
                                     RenderMode="@context.TextRenderMode"
                                     EmptyText="(nema teksta)"
                                     Class="question-list-math" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Tip">
                    <MudTooltip Text="@(context.Type == "multiple_choice" ? "Višestruki izbor" : "Otvoren odgovor")">
                        <MudIcon Icon="@(context.Type == "multiple_choice"
                                        ? Icons.Material.Filled.FormatListBulleted
                                        : Icons.Material.Filled.TextFields)"
                                 Size="Size.Small"
                                 Color="@(context.Type == "multiple_choice" ? Color.Primary : Color.Secondary)" />
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Kategorija">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                        @context.Category?.Name
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Podtema">
                    @if (!string.IsNullOrWhiteSpace(context.SubtopicName))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                            @context.SubtopicName
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Stanje">
                    <div class="d-flex flex-column gap-1">
                        <MudChip T="string" Size="Size.Small" Color="@GetPublishStateColor(context.PublishState)" Variant="Variant.Filled">
                            @GetPublishStateLabel(context.PublishState)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Color="@GetValidationStatusColor(context.ValidationStatus)" Variant="Variant.Outlined">
                            @GetValidationStatusLabel(context.ValidationStatus ?? ValidationStatusPending)
                        </MudChip>
                        @if (NeedsAttention(context))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">
                                Potrebna pažnja
                            </MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Tezina">
                    <MudRating ReadOnly="true" SelectedValue="@context.Difficulty" MaxValue="5" Size="Size.Small" />
                </MudTd>
                <MudTd DataLabel="Poslednja izmena">
                    @context.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    @if (!string.IsNullOrWhiteSpace(context.UpdatedBy))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">autor: @context.UpdatedBy</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Akcije" Style="text-align: right; white-space: nowrap;">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="async () => await ShowPreviewAsync(context)"
                                   title="Brzi pregled"
                                   aria-label="Brzi pregled" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Color="Color.Primary" 
                                   Size="Size.Small"
                                   Href="@($"/questions/{context.Id}/edit")"
                                   title="Izmeni pitanje"
                                   aria-label="Izmeni pitanje" />
                    <span style="display:inline-block; width:6px;"></span>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Color="Color.Error" 
                                   Size="Size.Small"
                                   OnClick="async () => await DeleteQuestionAsync(context)"
                                   title="Obrisi pitanje"
                                   aria-label="Obrisi pitanje" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="mt-4 d-flex justify-space-between align-center flex-wrap gap-2">
            <div class="d-flex align-center gap-3">
                <MudText Typo="Typo.body2">
                    Ukupno: <strong>@_totalCount</strong> pitanja |
                    Prikazano: <strong>@_questions.Count</strong> pitanja
                </MudText>
                <MudSelect T="int" Value="_pageSize" ValueChanged="OnPageSizeChangedAsync"
                           Dense="true" Variant="Variant.Outlined" Style="width:80px;"
                           Label="Po str.">
                    <MudSelectItem T="int" Value="10">10</MudSelectItem>
                    <MudSelectItem T="int" Value="25">25</MudSelectItem>
                    <MudSelectItem T="int" Value="50">50</MudSelectItem>
                </MudSelect>
            </div>
            <MudPagination Count="@_pageCount" 
                           Selected="@_currentPage" 
                           SelectedChanged="OnPageChangedAsync" />
        </div>
    }
</MudPaper>

@code {
    private List<QuestionListItem> _questions = new();
    private List<Category> _categories = new();
    private List<Subtopic> _subtopics = new();
    private bool _loading = true;
    private string _searchText = string.Empty;
    private int _selectedCategoryId = 0;
    private int _selectedSubtopicId = 0;
    private string _selectedType = string.Empty;
    private int? _selectedDifficulty;
    private string _selectedPublishState = string.Empty;
    private string _selectedAttentionFilter = string.Empty;
    private string _selectedValidationStatus = string.Empty;
    private string _selectedAuthor = string.Empty;
    private DateTime? _updatedAfterDate;
    private DateTime? _updatedBeforeDate;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private string? _loadError;
    private readonly string[] _publishStates =
    [
        QuestionPublishStates.Draft,
        QuestionPublishStates.Validated,
        QuestionPublishStates.Published,
        QuestionPublishStates.Archived
    ];
    private const string AttentionFilterProblematic = "problematic";
    private const string AttentionFilterWarnings = "warnings";
    private const string AttentionFilterReady = "ready";
    private const string ValidationStatusPending = "__pending";
    private const string FilterKeySearch = "search";
    private const string FilterKeyCategory = "category";
    private const string FilterKeySubtopic = "subtopic";
    private const string FilterKeyType = "type";
    private const string FilterKeyDifficulty = "difficulty";
    private const string FilterKeyPublishState = "publishState";
    private const string FilterKeyAttention = "attention";
    private const string FilterKeyValidation = "validation";
    private const string FilterKeyAuthor = "author";
    private const string FilterKeyUpdatedAfter = "updatedAfter";
    private const string FilterKeyUpdatedBefore = "updatedBefore";
    private int _pageCount => (_totalCount + _pageSize - 1) / _pageSize;
    private int ActiveFilterCount =>
        (!string.IsNullOrWhiteSpace(_searchText) ? 1 : 0) +
        (_selectedCategoryId > 0 ? 1 : 0) +
        (_selectedSubtopicId > 0 ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_selectedType) ? 1 : 0) +
        (_selectedDifficulty.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_selectedPublishState) ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_selectedAttentionFilter) ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_selectedValidationStatus) ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_selectedAuthor) ? 1 : 0) +
        (_updatedAfterDate.HasValue ? 1 : 0) +
        (_updatedBeforeDate.HasValue ? 1 : 0);
    private IReadOnlyList<ActiveFilterChip> ActiveFilterLabels
    {
        get
        {
            var filters = new List<ActiveFilterChip>();

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                filters.Add(new ActiveFilterChip(FilterKeySearch, $"Pretraga: {_searchText}"));
            }

            if (_selectedCategoryId > 0)
            {
                var categoryName = _categories.FirstOrDefault(x => x.Id == _selectedCategoryId)?.Name;
                filters.Add(new ActiveFilterChip(FilterKeyCategory, $"Kategorija: {categoryName ?? _selectedCategoryId.ToString()}"));
            }

            if (_selectedSubtopicId > 0)
            {
                var subtopicName = _subtopics.FirstOrDefault(x => x.Id == _selectedSubtopicId)?.Name;
                filters.Add(new ActiveFilterChip(FilterKeySubtopic, $"Podtema: {subtopicName ?? _selectedSubtopicId.ToString()}"));
            }

            if (!string.IsNullOrWhiteSpace(_selectedType))
            {
                filters.Add(new ActiveFilterChip(FilterKeyType, $"Tip: {(_selectedType == "multiple_choice" ? "Višestruki izbor" : "Otvoren odgovor")}"));
            }

            if (_selectedDifficulty.HasValue)
            {
                filters.Add(new ActiveFilterChip(FilterKeyDifficulty, $"Težina: {_selectedDifficulty.Value}"));
            }

            if (!string.IsNullOrWhiteSpace(_selectedPublishState))
            {
                filters.Add(new ActiveFilterChip(FilterKeyPublishState, $"Status: {GetPublishStateLabel(_selectedPublishState)}"));
            }

            if (!string.IsNullOrWhiteSpace(_selectedAttentionFilter))
            {
                filters.Add(new ActiveFilterChip(FilterKeyAttention, $"Pažnja: {GetAttentionFilterLabel(_selectedAttentionFilter)}"));
            }

            if (!string.IsNullOrWhiteSpace(_selectedValidationStatus))
            {
                filters.Add(new ActiveFilterChip(FilterKeyValidation, $"Validacija: {GetValidationStatusFilterLabel(_selectedValidationStatus)}"));
            }

            if (!string.IsNullOrWhiteSpace(_selectedAuthor))
            {
                filters.Add(new ActiveFilterChip(FilterKeyAuthor, $"Autor: {_selectedAuthor}"));
            }

            if (_updatedAfterDate.HasValue)
            {
                filters.Add(new ActiveFilterChip(FilterKeyUpdatedAfter, $"Izmenjeno nakon: {_updatedAfterDate.Value:dd.MM.yyyy}"));
            }

            if (_updatedBeforeDate.HasValue)
            {
                filters.Add(new ActiveFilterChip(FilterKeyUpdatedBefore, $"Izmenjeno pre: {_updatedBeforeDate.Value:dd.MM.yyyy}"));
            }

            return filters;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _categories = await db.Categories
                .AsNoTracking()
                .OrderBy(c => c.Name)
                .ToListAsync();

            _subtopics = await db.Subtopics
                .AsNoTracking()
                .OrderBy(s => s.Name)
                .ToListAsync();

            await LoadQuestionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing questions index");
            _loadError = "Greška pri učitavanju pitanja. Pokušajte ponovo za nekoliko trenutaka.";
            _loading = false;
        }
    }

    private async Task LoadQuestionsAsync()
    {
        _currentPage = 1;
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var query = BuildFilteredQuery(db);

            _totalCount = await query.CountAsync();
            _questions = await ApplyDefaultOrdering(query)
                .Skip((_currentPage - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading questions");
            _loadError = "Greška pri učitavanju pitanja. Proverite bazu i pokušajte ponovo.";
            _questions.Clear();
            Snackbar.Add("Greška pri učitavanju pitanja", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _questions = await ApplyDefaultOrdering(BuildFilteredQuery(db))
                .Skip((_currentPage - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing questions page to {Page}", page);
            _loadError = "Greška pri učitavanju sledeće stranice pitanja.";
            Snackbar.Add("Greška pri učitavanju sledeće stranice pitanja", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private IQueryable<QuestionListItem> BuildFilteredQuery(AdminDbContext db)
    {
        var query =
            from question in db.Questions.AsNoTracking()
            where !question.IsDeleted
            join category in db.Categories.AsNoTracking() on question.CategoryId equals category.Id into categoryJoin
            from category in categoryJoin.DefaultIfEmpty()
            join subtopic in db.Subtopics.AsNoTracking() on question.SubtopicId equals subtopic.Id into subtopicJoin
            from subtopic in subtopicJoin.DefaultIfEmpty()
            join draft in db.QuestionDrafts.AsNoTracking() on question.CurrentDraftId equals draft.Id into draftJoin
            from currentDraft in draftJoin.DefaultIfEmpty()
            select new QuestionListItem
            {
                Id = question.Id,
                Text = question.Text,
                TextFormat = question.TextFormat,
                TextRenderMode = question.TextRenderMode,
                Difficulty = question.Difficulty,
                UpdatedAt = question.UpdatedAt,
                UpdatedBy = question.UpdatedBy,
                Category = category,
                CategoryId = question.CategoryId,
                SubtopicId = question.SubtopicId,
                SubtopicName = subtopic != null ? subtopic.Name : null,
                Type = question.Type,
                PublishState = question.PublishState,
                ValidationStatus = currentDraft != null ? currentDraft.ValidationStatus : null,
                OptionCount = 0,
                StepCount = 0
            };

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(q => EF.Functions.ILike(q.Text, $"%{_searchText}%"));
        }

        if (_selectedCategoryId > 0)
        {
            query = query.Where(q => q.CategoryId == _selectedCategoryId);
        }

        if (_selectedSubtopicId > 0)
        {
            query = query.Where(q => q.SubtopicId == _selectedSubtopicId);
        }

        if (!string.IsNullOrWhiteSpace(_selectedType))
        {
            query = query.Where(q => q.Type == _selectedType);
        }

        if (_selectedDifficulty.HasValue)
        {
            query = query.Where(q => q.Difficulty == _selectedDifficulty.Value);
        }

        if (!string.IsNullOrWhiteSpace(_selectedPublishState))
        {
            query = query.Where(q => q.PublishState == _selectedPublishState);
        }

        if (!string.IsNullOrWhiteSpace(_selectedAuthor))
        {
            query = query.Where(q => q.UpdatedBy != null && EF.Functions.ILike(q.UpdatedBy, $"%{_selectedAuthor}%"));
        }

        if (!string.IsNullOrWhiteSpace(_selectedValidationStatus))
        {
            query = _selectedValidationStatus == ValidationStatusPending
                ? query.Where(q => q.ValidationStatus == null)
                : query.Where(q => q.ValidationStatus == _selectedValidationStatus);
        }

        if (!string.IsNullOrWhiteSpace(_selectedAttentionFilter))
        {
            query = _selectedAttentionFilter switch
            {
                AttentionFilterProblematic => query.Where(q => q.ValidationStatus == QuestionValidationStatuses.Failed),
                AttentionFilterWarnings => query.Where(q => q.ValidationStatus == QuestionValidationStatuses.PassedWithWarnings),
                AttentionFilterReady => query.Where(q =>
                    q.PublishState != QuestionPublishStates.Published &&
                    q.ValidationStatus == QuestionValidationStatuses.Passed),
                _ => query
            };
        }

        if (_updatedAfterDate.HasValue)
        {
            var updatedAfterUtc = DateTime.SpecifyKind(_updatedAfterDate.Value.Date, DateTimeKind.Utc);
            query = query.Where(q => q.UpdatedAt >= updatedAfterUtc);
        }

        if (_updatedBeforeDate.HasValue)
        {
            var updatedBeforeUtcExclusive = DateTime.SpecifyKind(_updatedBeforeDate.Value.Date.AddDays(1), DateTimeKind.Utc);
            query = query.Where(q => q.UpdatedAt < updatedBeforeUtcExclusive);
        }

        return query;
    }

    private static IOrderedQueryable<QuestionListItem> ApplyDefaultOrdering(IQueryable<QuestionListItem> query)
        => query
            .OrderByDescending(q => q.UpdatedAt)
            .ThenByDescending(q => q.Id);

    private void ResetSearch()
    {
        _searchText = string.Empty;
        _selectedCategoryId = 0;
        _selectedSubtopicId = 0;
        _selectedType = string.Empty;
        _selectedDifficulty = null;
        _selectedPublishState = string.Empty;
        _selectedAttentionFilter = string.Empty;
        _selectedValidationStatus = string.Empty;
        _selectedAuthor = string.Empty;
        _updatedAfterDate = null;
        _updatedBeforeDate = null;
    }

    private async Task ResetSearchAndReloadAsync()
    {
        ResetSearch();
        await LoadQuestionsAsync();
    }

    private async Task RemoveFilterAsync(string filterKey)
    {
        switch (filterKey)
        {
            case FilterKeySearch:
                _searchText = string.Empty;
                break;
            case FilterKeyCategory:
                _selectedCategoryId = 0;
                break;
            case FilterKeySubtopic:
                _selectedSubtopicId = 0;
                break;
            case FilterKeyType:
                _selectedType = string.Empty;
                break;
            case FilterKeyDifficulty:
                _selectedDifficulty = null;
                break;
            case FilterKeyPublishState:
                _selectedPublishState = string.Empty;
                break;
            case FilterKeyAttention:
                _selectedAttentionFilter = string.Empty;
                break;
            case FilterKeyValidation:
                _selectedValidationStatus = string.Empty;
                break;
            case FilterKeyAuthor:
                _selectedAuthor = string.Empty;
                break;
            case FilterKeyUpdatedAfter:
                _updatedAfterDate = null;
                break;
            case FilterKeyUpdatedBefore:
                _updatedBeforeDate = null;
                break;
            default:
                return;
        }

        await LoadQuestionsAsync();
    }

