@page "/questions"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Services
@using MathLearning.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MathLearning.Admin.Components.Dialogs
@using MudBlazor
@inject IDbContextFactory<AdminDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<Index> Logger

<PageTitle>Pitanja - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Quiz" Class="mr-2" />
    Pitanja
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Upravljajte pitanjima i odgovorima
</MudText>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
}

<MudPaper Elevation="4" Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchText" 
                          Placeholder="Pretraži pitanja..." 
                          Variant="Variant.Outlined"
                          DebounceInterval="400"
                          TextChanged="OnSearchTextChangedAsync"
                          Clearable="true"
                          OnClearButtonClick="ResetSearchAndReloadAsync" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_selectedCategoryId" 
                       Label="Kategorija" 
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var category in _categories)
                {
                    <MudSelectItem Value="@category.Id">@category.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedType" 
                       Label="Tip pitanja" 
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="string" Value="@("multiple_choice")">Višestruki izbor</MudSelectItem>
                <MudSelectItem T="string" Value="@("open_answer")">Otvoren odgovor</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="int?" @bind-Value="_selectedDifficulty"
                       Label="Težina"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @for (var difficulty = 1; difficulty <= 5; difficulty++)
                {
                    <MudSelectItem T="int?" Value="@((int?)difficulty)">@difficulty</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedPublishState"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var status in _publishStates)
                {
                    <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker Label="Izmenjeno nakon"
                           Variant="Variant.Outlined"
                           Date="@_updatedAfterDate"
                           DateChanged="OnUpdatedAfterDateChangedAsync"
                           Clearable="true"
                           Editable="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudButton OnClick="LoadQuestionsAsync" 
                       Color="Color.Primary" 
                       Variant="Variant.Filled"
                       FullWidth="true">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
                Pretraži
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="4" Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Lista Pitanja</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Href="/questions/new"
                   StartIcon="@Icons.Material.Filled.Add">
            Dodaj Pitanje
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_questions.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            Nema pitanja sa izabranim kriterijumima. Kliknite "Dodaj Pitanje" da kreirate prvo.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_questions" 
                  Hover="true" 
                  Dense="true"
                  Elevation="0">
            <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.Id)">ID</MudTableSortLabel></MudTh>
                <MudTh>Tekst</MudTh>
                <MudTh>Tip</MudTh>
                <MudTh>Kategorija</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.PublishState)">Stanje</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.Difficulty)">Tezina</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<QuestionListItem, object>(x => x.UpdatedAt)" InitialDirection="SortDirection.Descending">Poslednja izmena</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right; width: 140px;">Akcije</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="Tekst">
                    <div class="question-list-preview">
                        <MathPreview Content="@context.Text"
                                     Format="@context.TextFormat"
                                     RenderMode="@context.TextRenderMode"
                                     EmptyText="(nema teksta)"
                                     Class="question-list-math" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Tip">
                    <MudTooltip Text="@(context.Type == "multiple_choice" ? "Višestruki izbor" : "Otvoren odgovor")">
                        <MudIcon Icon="@(context.Type == "multiple_choice"
                                        ? Icons.Material.Filled.FormatListBulleted
                                        : Icons.Material.Filled.TextFields)"
                                 Size="Size.Small"
                                 Color="@(context.Type == "multiple_choice" ? Color.Primary : Color.Secondary)" />
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Kategorija">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                        @context.Category?.Name
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Stanje">
                    <div class="d-flex flex-column gap-1">
                        <MudChip T="string" Size="Size.Small" Color="@GetPublishStateColor(context.PublishState)" Variant="Variant.Filled">
                            @GetPublishStateLabel(context.PublishState)
                        </MudChip>
                        @if (!string.IsNullOrWhiteSpace(context.ValidationStatus))
                        {
                            <MudChip T="string" Size="Size.Small" Color="@GetValidationStatusColor(context.ValidationStatus)" Variant="Variant.Outlined">
                                @GetValidationStatusLabel(context.ValidationStatus)
                            </MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Tezina">
                    <MudRating ReadOnly="true" SelectedValue="@context.Difficulty" MaxValue="5" Size="Size.Small" />
                </MudTd>
                <MudTd DataLabel="Poslednja izmena">
                    @context.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    @if (!string.IsNullOrWhiteSpace(context.UpdatedBy))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">autor: @context.UpdatedBy</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Akcije" Style="text-align: right; white-space: nowrap;">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="async () => await ShowPreviewAsync(context)"
                                   title="Brzi pregled"
                                   aria-label="Brzi pregled" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Color="Color.Primary" 
                                   Size="Size.Small"
                                   Href="@($"/questions/{context.Id}/edit")"
                                   title="Izmeni pitanje"
                                   aria-label="Izmeni pitanje" />
                    <span style="display:inline-block; width:6px;"></span>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Color="Color.Error" 
                                   Size="Size.Small"
                                   OnClick="async () => await DeleteQuestionAsync(context)"
                                   title="Obrisi pitanje"
                                   aria-label="Obrisi pitanje" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="mt-4 d-flex justify-space-between align-center flex-wrap gap-2">
            <div class="d-flex align-center gap-3">
                <MudText Typo="Typo.body2">
                    Ukupno: <strong>@_totalCount</strong> pitanja |
                    Prikazano: <strong>@_questions.Count</strong> pitanja
                </MudText>
                <MudSelect T="int" Value="_pageSize" ValueChanged="OnPageSizeChangedAsync"
                           Dense="true" Variant="Variant.Outlined" Style="width:80px;"
                           Label="Po str.">
                    <MudSelectItem T="int" Value="10">10</MudSelectItem>
                    <MudSelectItem T="int" Value="25">25</MudSelectItem>
                    <MudSelectItem T="int" Value="50">50</MudSelectItem>
                </MudSelect>
            </div>
            <MudPagination Count="@_pageCount" 
                           Selected="@_currentPage" 
                           SelectedChanged="OnPageChangedAsync" />
        </div>
    }
</MudPaper>

@code {
    private List<QuestionListItem> _questions = new();
    private List<Category> _categories = new();
    private bool _loading = true;
    private string _searchText = string.Empty;
    private int _selectedCategoryId = 0;
    private string _selectedType = string.Empty;
    private int? _selectedDifficulty;
    private string _selectedPublishState = string.Empty;
    private DateTime? _updatedAfterDate;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalCount = 0;
    private string? _loadError;
    private readonly string[] _publishStates =
    [
        QuestionPublishStates.Draft,
        QuestionPublishStates.Validated,
        QuestionPublishStates.Published,
        QuestionPublishStates.Archived
    ];
    private int _pageCount => (_totalCount + _pageSize - 1) / _pageSize;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _categories = await db.Categories
                .AsNoTracking()
                .OrderBy(c => c.Name)
                .ToListAsync();

            await LoadQuestionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing questions index");
            _loadError = "Greška pri učitavanju pitanja. Pokušajte ponovo za nekoliko trenutaka.";
            _loading = false;
        }
    }

    private async Task LoadQuestionsAsync()
    {
        _currentPage = 1;
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var query = BuildFilteredQuery(db);

            _totalCount = await query.CountAsync();
            _questions = await query
                .OrderBy(q => q.Id)
                .Skip((_currentPage - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading questions");
            _loadError = "Greška pri učitavanju pitanja. Proverite bazu i pokušajte ponovo.";
            _questions.Clear();
            Snackbar.Add("Greška pri učitavanju pitanja", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _questions = await BuildFilteredQuery(db)
                .OrderBy(q => q.Id)
                .Skip((_currentPage - 1) * _pageSize)
                .Take(_pageSize)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing questions page to {Page}", page);
            _loadError = "Greška pri učitavanju sledeće stranice pitanja.";
            Snackbar.Add("Greška pri učitavanju sledeće stranice pitanja", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private IQueryable<QuestionListItem> BuildFilteredQuery(AdminDbContext db)
    {
        var query =
            from question in db.Questions.AsNoTracking()
            where !question.IsDeleted
            join category in db.Categories.AsNoTracking() on question.CategoryId equals category.Id into categoryJoin
            from category in categoryJoin.DefaultIfEmpty()
            join draft in db.QuestionDrafts.AsNoTracking() on question.CurrentDraftId equals draft.Id into draftJoin
            from currentDraft in draftJoin.DefaultIfEmpty()
            select new QuestionListItem
            {
                Id = question.Id,
                Text = question.Text,
                TextFormat = question.TextFormat,
                TextRenderMode = question.TextRenderMode,
                Difficulty = question.Difficulty,
                UpdatedAt = question.UpdatedAt,
                UpdatedBy = question.UpdatedBy,
                Category = category,
                CategoryId = question.CategoryId,
                Type = question.Type,
                PublishState = question.PublishState,
                ValidationStatus = currentDraft != null ? currentDraft.ValidationStatus : null,
                OptionCount = 0,
                StepCount = 0
            };

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(q => EF.Functions.ILike(q.Text, $"%{_searchText}%"));
        }

        if (_selectedCategoryId > 0)
        {
            query = query.Where(q => q.CategoryId == _selectedCategoryId);
        }

        if (!string.IsNullOrWhiteSpace(_selectedType))
        {
            query = query.Where(q => q.Type == _selectedType);
        }

        if (_selectedDifficulty.HasValue)
        {
            query = query.Where(q => q.Difficulty == _selectedDifficulty.Value);
        }

        if (!string.IsNullOrWhiteSpace(_selectedPublishState))
        {
            query = query.Where(q => q.PublishState == _selectedPublishState);
        }

        if (_updatedAfterDate.HasValue)
        {
            var updatedAfterUtc = DateTime.SpecifyKind(_updatedAfterDate.Value.Date, DateTimeKind.Utc);
            query = query.Where(q => q.UpdatedAt >= updatedAfterUtc);
        }

        return query;
    }

    private void ResetSearch()
    {
        _searchText = string.Empty;
        _selectedCategoryId = 0;
        _selectedType = string.Empty;
        _selectedDifficulty = null;
        _selectedPublishState = string.Empty;
        _updatedAfterDate = null;
    }

    private async Task ResetSearchAndReloadAsync()
    {
        ResetSearch();
        await LoadQuestionsAsync();
    }

    private async Task OnSearchTextChangedAsync(string value)
    {
        _searchText = value;
        await LoadQuestionsAsync();
    }

    private async Task OnPageSizeChangedAsync(int newSize)
    {
        _pageSize = newSize;
        _currentPage = 1;
        await LoadQuestionsAsync();
    }

    private async Task OnUpdatedAfterDateChangedAsync(DateTime? date)
    {
        _updatedAfterDate = date;
        await LoadQuestionsAsync();
    }

    private async Task DeleteQuestionAsync(QuestionListItem question)
    {
        // Fetch actual counts lazily — only needed for the confirm dialog message
        int optionCount = 0;
        int stepCount = 0;
        try
        {
            await using var dbCounts = await DbFactory.CreateDbContextAsync();
            optionCount = await dbCounts.Options.CountAsync(o => EF.Property<int>(o, "QuestionId") == question.Id);
            stepCount = await dbCounts.QuestionSteps.CountAsync(s => s.QuestionId == question.Id);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not fetch option/step counts for question {Id}", question.Id);
        }

        var dialogParameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = "Potvrda brisanja",
            [nameof(ConfirmDialog.Message)] = DeleteImpactFormatter.BuildQuestionDeleteMessage(
                question.Id,
                optionCount,
                stepCount),
            [nameof(ConfirmDialog.ConfirmText)] = "Obrisi",
            [nameof(ConfirmDialog.CancelText)] = "Odustani",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };
        var dialogRef = await DialogService.ShowAsync<ConfirmDialog>("Potvrda", dialogParameters, new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small
        });
        var dialogResult = await dialogRef.Result;
        if (dialogResult?.Canceled ?? true)
        {
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Questions.FirstOrDefaultAsync(x => x.Id == question.Id);
            if (entity is null)
            {
                Snackbar.Add("Pitanje više ne postoji.", Severity.Warning);
                _questions.Remove(question);
                _totalCount = Math.Max(0, _totalCount - 1);
                return;
            }

            entity.SoftDelete();
            await db.SaveChangesAsync();
            _questions.Remove(question);
            _totalCount--;

            var deletedId = question.Id;
            Snackbar.Add("Pitanje je obrisano", Severity.Success, config =>
            {
                config.Action = "Poništi";
                config.ActionColor = Color.Warning;
                config.OnClick = async _ => await UndoDeleteAsync(deletedId);
                config.VisibleStateDuration = 6000;
            });
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting question");
            Snackbar.Add($"Greška pri brisanju: {ex.Message}", Severity.Error);
        }
    }

    private async Task UndoDeleteAsync(int questionId)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Questions.FirstOrDefaultAsync(x => x.Id == questionId);
            if (entity is null)
            {
                Snackbar.Add("Nije moguće poništiti — pitanje nije pronađeno.", Severity.Warning);
                return;
            }

            entity.Restore();
            await db.SaveChangesAsync();
            Snackbar.Add("Brisanje poništeno", Severity.Success);
            await LoadQuestionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error restoring question {QuestionId}", questionId);
            Snackbar.Add($"Greška pri poništavanju: {ex.Message}", Severity.Error);
        }
    }

    private async Task ShowPreviewAsync(QuestionListItem question)
    {
        var parameters = new DialogParameters
        {
            [nameof(QuestionPreviewDialog.QuestionId)] = question.Id
        };
        await DialogService.ShowAsync<QuestionPreviewDialog>(
            $"Pregled pitanja #{question.Id}",
            parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static Color GetPublishStateColor(string publishState) => publishState switch
    {
        QuestionPublishStates.Published => Color.Success,
        QuestionPublishStates.Validated => Color.Info,
        QuestionPublishStates.Archived => Color.Secondary,
        _ => Color.Warning
    };

    private static string GetPublishStateLabel(string publishState) => publishState switch
    {
        QuestionPublishStates.Published => "Objavljeno",
        QuestionPublishStates.Validated => "Validirano",
        QuestionPublishStates.Archived => "Arhivirano",
        _ => "Draft"
    };

    private static Color GetValidationStatusColor(string validationStatus) => validationStatus switch
    {
        QuestionValidationStatuses.Passed => Color.Success,
        QuestionValidationStatuses.PassedWithWarnings => Color.Warning,
        QuestionValidationStatuses.Failed => Color.Error,
        _ => Color.Info
    };

    private static string GetValidationStatusLabel(string validationStatus) => validationStatus switch
    {
        QuestionValidationStatuses.Passed => "Bez grešaka",
        QuestionValidationStatuses.PassedWithWarnings => "Upozorenja",
        QuestionValidationStatuses.Failed => "Problematično",
        _ => "Na čekanju"
    };

    private sealed class QuestionListItem
    {
        public int Id { get; init; }
        public string Text { get; init; } = string.Empty;
        public MathLearning.Domain.Enums.ContentFormat TextFormat { get; init; } = MathLearning.Domain.Enums.ContentFormat.MarkdownWithMath;
        public MathLearning.Domain.Enums.RenderMode TextRenderMode { get; init; } = MathLearning.Domain.Enums.RenderMode.Auto;
        public int Difficulty { get; init; }
        public DateTime UpdatedAt { get; init; }
        public string? UpdatedBy { get; init; }
        public Category? Category { get; init; }
        public int CategoryId { get; init; }
        public string Type { get; init; } = string.Empty;
        public string PublishState { get; init; } = QuestionPublishStates.Draft;
        public string? ValidationStatus { get; init; }
        public int OptionCount { get; init; }
        public int StepCount { get; init; }
    }
}
