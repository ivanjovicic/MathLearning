@page "/questions/new"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@attribute [Authorize]
@using MathLearning.Admin.Data
@using MathLearning.Admin.Models
@using MathLearning.Application.Content
@using MathLearning.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json

@inject AdminDbContext Db
@inject IMathContentSanitizer Sanitizer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<New> Logger
@inject IJSRuntime Js

<PageTitle>Novo Pitanje - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
    Dodaj Novo Pitanje
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Authoring za math sadržaj sa format metadata i preview-em
</MudText>

<NavigationLock ConfirmExternalNavigation="@HasUnsavedChanges" OnBeforeInternalNavigation="ConfirmNavigationAsync" />

<QuestionEditor Model="@Model"
                Categories="@Categories"
                Subtopics="@Subtopics"
                IsSaving="@IsSaving"
                SaveButtonText="Sačuvaj pitanje"
                ValidationErrors="@ValidationErrors"
                OnSave="SaveAsync" />

@code {
    private readonly QuestionEditorModel Model = new();
    private QuestionEditorHelper? _editorHelper;
    private List<Category> Categories { get; set; } = [];
    private List<Subtopic> Subtopics { get; set; } = [];
    private bool IsSaving { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private string _initialSnapshot = string.Empty;
    private bool HasUnsavedChanges => !IsSaving && !string.Equals(_initialSnapshot, _editorHelper?.CreateModelSnapshot(Model), StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        _editorHelper = new QuestionEditorHelper(Sanitizer);

        Categories = await Db.Categories
            .AsNoTracking()
            .OrderBy(c => c.Name)
            .ToListAsync();

        Subtopics = await Db.Subtopics
            .AsNoTracking()
            .Include(x => x.Topic)
            .OrderBy(x => x.Topic!.Name)
            .ThenBy(x => x.Name)
            .ToListAsync();

        if (Categories.Count > 0)
        {
            Model.CategoryId = Categories[0].Id;
        }

        if (Subtopics.Count > 0)
        {
            Model.SubtopicId = Subtopics[0].Id;
        }

        if (Model.Options.Count > 0)
        {
            Model.Options[0].IsCorrect = true;
        }

        MarkSnapshot();
    }

    private async Task SaveAsync()
    {
        if (_editorHelper is null)
        {
            return;
        }

        ValidationErrors = _editorHelper.ValidateModel(Model);
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            await using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                var question = new Question(
                    _editorHelper.Sanitize(Model.Text, Model.TextFormat),
                    Model.Difficulty,
                    Model.CategoryId,
                    _editorHelper.Sanitize(Model.Explanation, Model.ExplanationFormat));

                _editorHelper.ApplyQuestionFields(question, Model);
                question.ReplaceOptions(_editorHelper.BuildOptions(Model));

                Db.Questions.Add(question);
                await Db.SaveChangesAsync();

                var steps = _editorHelper.BuildSteps(question.Id, Model);
                if (steps.Count > 0)
                {
                    question.ReplaceSteps(steps);
                    await Db.SaveChangesAsync();
                }

                await tx.CommitAsync();
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }

            Snackbar.Add("Pitanje je uspešno dodato.", Severity.Success);
            MarkSnapshot();
            Nav.NavigateTo("/questions");
        }
        catch (DbUpdateConcurrencyException)
        {
            ValidationErrors = ["Pitanje je izmenjeno od strane drugog korisnika. Osvežite stranicu i ponovite izmene."];
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Database error saving question");
            ValidationErrors = ["Greška pri čuvanju u bazu podataka. Pokušajte ponovo."];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving question");
            ValidationErrors = ["Neočekivana greška. Kontaktirajte administratora."];
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void MarkSnapshot()
    {
        _initialSnapshot = _editorHelper?.CreateModelSnapshot(Model) ?? string.Empty;
    }

    private async Task ConfirmNavigationAsync(LocationChangingContext context)
    {
        if (!HasUnsavedChanges)
        {
            return;
        }

        var shouldLeave = await Js.InvokeAsync<bool>("confirm", "Imate nesacuvane izmene. Da li sigurno zelite da napustite stranicu?");
        if (!shouldLeave)
        {
            context.PreventNavigation();
        }
    }
}
