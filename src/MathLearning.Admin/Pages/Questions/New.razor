@page "/questions/new"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using MathLearning.Admin.Data
@using MathLearning.Admin.Models
@using MathLearning.Application.Content
@using MathLearning.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using MudBlazor

@inject AdminDbContext Db
@inject IMathContentSanitizer Sanitizer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<New> Logger

<PageTitle>Novo Pitanje - MathLearning Admin</PageTitle>

<MudText Typo="Typo.h3" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
    Dodaj Novo Pitanje
</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">
    Authoring za math sadržaj sa format metadata i preview-em
</MudText>

<QuestionEditor Model="@Model"
                Categories="@Categories"
                Subtopics="@Subtopics"
                IsSaving="@IsSaving"
                SaveButtonText="Sačuvaj pitanje"
                ValidationErrors="@ValidationErrors"
                OnSave="SaveAsync" />

@code {
    private readonly QuestionEditorModel Model = new();
    private List<Category> Categories { get; set; } = [];
    private List<Subtopic> Subtopics { get; set; } = [];
    private bool IsSaving { get; set; }
    private List<string> ValidationErrors { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Categories = await Db.Categories
            .AsNoTracking()
            .OrderBy(c => c.Name)
            .ToListAsync();

        Subtopics = await Db.Subtopics
            .AsNoTracking()
            .Include(x => x.Topic)
            .OrderBy(x => x.Topic!.Name)
            .ThenBy(x => x.Name)
            .ToListAsync();

        if (Categories.Count > 0)
        {
            Model.CategoryId = Categories[0].Id;
        }

        if (Subtopics.Count > 0)
        {
            Model.SubtopicId = Subtopics[0].Id;
        }

        if (Model.Options.Count > 0)
        {
            Model.Options[0].IsCorrect = true;
        }
    }

    private async Task SaveAsync()
    {
        ValidationErrors = ValidateModel();
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            await using var tx = await Db.Database.BeginTransactionAsync();
            try
            {
                var question = new Question(
                    Sanitize(Model.Text, Model.TextFormat),
                    Model.Difficulty,
                    Model.CategoryId,
                    Sanitize(Model.Explanation, Model.ExplanationFormat));

                ApplyQuestionFields(question);
                question.ReplaceOptions(BuildOptions());

                Db.Questions.Add(question);
                await Db.SaveChangesAsync();

                var steps = BuildSteps(question.Id);
                if (steps.Count > 0)
                {
                    question.ReplaceSteps(steps);
                    await Db.SaveChangesAsync();
                }

                await tx.CommitAsync();
            }
            catch
            {
                await tx.RollbackAsync();
                throw;
            }

            Snackbar.Add("Pitanje je uspešno dodato.", Severity.Success);
            Nav.NavigateTo("/questions");
        }
        catch (DbUpdateConcurrencyException)
        {
            ValidationErrors = ["Pitanje je izmenjeno od strane drugog korisnika. Osvežite stranicu i ponovite izmene."];
        }
        catch (DbUpdateException ex)
        {
            Logger.LogError(ex, "Database error saving question");
            ValidationErrors = ["Greška pri čuvanju u bazu podataka. Pokušajte ponovo."];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving question");
            ValidationErrors = ["Neočekivana greška. Kontaktirajte administratora."];
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void ApplyQuestionFields(Question question)
    {
        question.SetType(Model.Type);
        question.SetCategory(Model.CategoryId);
        question.SetSubtopic(Model.SubtopicId);
        question.SetDifficulty(Model.Difficulty);
        question.SetExplanation(Sanitize(Model.Explanation, Model.ExplanationFormat));
        question.SetHintFormula(Sanitize(Model.HintFormula, Model.HintFormat));
        question.SetHintClue(Sanitize(Model.HintClue, Model.HintFormat));
        question.SetHintFull(Sanitize(Model.HintFull, Model.HintFormat));
        question.SetTextFormat(Model.TextFormat);
        question.SetExplanationFormat(Model.ExplanationFormat);
        question.SetHintFormat(Model.HintFormat);
        question.SetTextRenderMode(Model.TextRenderMode);
        question.SetExplanationRenderMode(Model.ExplanationRenderMode);
        question.SetHintRenderMode(Model.HintRenderMode);
        question.SetSemanticsAltText(ResolveSemantics(Model.SemanticsAltText, Model.Text, Model.TextFormat));
        question.SetCorrectAnswer(ResolveCorrectAnswer());
        question.SetHintDifficulty(Model.Difficulty switch
        {
            <= 2 => 1,
            3 or 4 => 2,
            _ => 3
        });
    }

    private List<QuestionOption> BuildOptions()
        => Model.Options
            .Where(x => !string.IsNullOrWhiteSpace(x.Text))
            .Select((x, i) => new QuestionOption(
                Sanitize(x.Text, x.TextFormat),
                x.IsCorrect,
                x.TextFormat,
                x.RenderMode,
                ResolveSemantics(x.SemanticsAltText, x.Text, x.TextFormat),
                i + 1))
            .ToList();

    private List<QuestionStep> BuildSteps(int questionId)
        => Model.Steps
            .Where(x => !string.IsNullOrWhiteSpace(x.Text))
            .OrderBy(x => x.Order)
            .Select(x => new QuestionStep(
                questionId,
                x.Order,
                Sanitize(x.Text, x.TextFormat),
                Sanitize(x.Hint, x.HintFormat),
                x.Highlight,
                x.TextFormat,
                x.HintFormat,
                x.TextRenderMode,
                x.HintRenderMode,
                ResolveSemantics(x.SemanticsAltText, x.Text, x.TextFormat)))
            .ToList();

    private string? ResolveCorrectAnswer()
    {
        if (!string.Equals(Model.Type, "multiple_choice", StringComparison.OrdinalIgnoreCase))
        {
            return Sanitize(Model.CorrectAnswer, Model.TextFormat);
        }

        var correct = Model.Options.FirstOrDefault(x => x.IsCorrect)?.Text;
        return Sanitize(correct, Model.TextFormat);
    }

    private List<string> ValidateModel()
        => QuestionEditorValidation.Validate(Model);

    private string Sanitize(string? raw, MathLearning.Domain.Enums.ContentFormat format)
        => Sanitizer.NormalizeMathContent(raw, format);

    private string? ResolveSemantics(string? semanticsAltText, string? raw, MathLearning.Domain.Enums.ContentFormat format)
        => !string.IsNullOrWhiteSpace(semanticsAltText)
            ? semanticsAltText.Trim()
            : Sanitizer.GenerateSemanticsAltText(raw, format);
}
