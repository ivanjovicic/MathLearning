@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                       Color="Color.Inherit" 
                       Edge="Edge.Start" 
                       OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">MathLearning Admin</MudText>
        <MudSpacer />
        
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-4">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                    @context.User.Identity?.Name
                </MudText>
                <MudButton Href="/logout" 
                           Variant="Variant.Text" 
                           Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Logout">
                    Odjavi se
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" 
               Elevation="2" 
               ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigacija</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" 
                        Icon="@Icons.Material.Filled.Dashboard" 
                        Match="NavLinkMatch.All">
                Dashboard
            </MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/categories" 
                        Icon="@Icons.Material.Filled.Category">
                Kategorije
            </MudNavLink>
            <MudNavLink Href="/questions" 
                        Icon="@Icons.Material.Filled.Quiz">
                Pitanja
            </MudNavLink>
            <MudNavLink Href="/questions/new" 
                        Icon="@Icons.Material.Filled.Add">
                Novo Pitanje
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
