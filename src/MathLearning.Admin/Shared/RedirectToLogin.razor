@using Microsoft.AspNetCore.Components
@using MathLearning.Admin.Services
@inject NavigationManager Nav
@inject ILogger<RedirectToLogin> Logger

<div style="display: flex; justify-content: center; align-items: center; min-height: 100vh;">
    <div style="text-align: center;">
        <h3>Redirecting to login...</h3>
        <p>Please wait...</p>
    </div>
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var currentUri = Nav.Uri;
        var returnUrl = Nav.ToBaseRelativePath(currentUri);
        Logger.LogInformation("RedirectToLogin triggered. Current URI: {CurrentUri}, ReturnUrl: {ReturnUrl}", currentUri, returnUrl);

        if (returnUrl.StartsWith("login", StringComparison.OrdinalIgnoreCase))
        {
            Logger.LogInformation("Already on login page, skipping redirect");
            return;
        }

        var localReturnUrl = ReturnUrlSanitizer.NormalizeLocalReturnUrl(
            string.IsNullOrWhiteSpace(returnUrl) ? "/" : "/" + returnUrl.TrimStart('/'));
        var loginUrl = localReturnUrl == "/"
            ? "/login"
            : $"/login?returnUrl={Uri.EscapeDataString(localReturnUrl)}";

        try
        {
            Nav.NavigateTo(loginUrl, forceLoad: true);
            Logger.LogInformation("Navigation completed successfully");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Navigation failed in RedirectToLogin");
        }
    }
}
