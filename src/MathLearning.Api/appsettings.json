{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Username=postgres;Password=postgres;Database=mathlearning;Pooling=true;"
  },
  "JwtSettings": {
    "SecretKey": "MathLearning-SuperSecretKey-2024-AtLeast32Chars!",
    "Issuer": "MathLearningAPI",
    "Audience": "MathLearningApp"
  },

  "RateLimiting": {
    "Sliding": {
      "Limit": 100,
      "WindowSeconds": 60
    }
  },
  "DesignTokens": {
    "BaseWidth": 390,
    "CacheTtlMinutes": 60,
    "Themes": {
      "light": {
        "Spacing": {
          "xs": 4,
          "s": 8,
          "m": 16,
          "l": 24,
          "xl": 32
        },
        "Typography": {
          "titleLarge": 24,
          "bodyLarge": 16,
          "caption": 12
        },
        "Radius": {
          "small": 8,
          "medium": 16,
          "large": 24
        },
        "Colors": {
          "background": "#FFF8F1",
          "surface": "#FFFFFF",
          "textPrimary": "#1F2937",
          "textSecondary": "#6B7280",
          "accent": "#F97316"
        },
        "IconSizes": {
          "s": 16,
          "m": 20,
          "l": 24
        },
        "MotionDurations": {
          "fast": 120,
          "normal": 220,
          "slow": 320
        }
      },
      "dark": {
        "Colors": {
          "background": "#111827",
          "surface": "#1F2937",
          "textPrimary": "#F9FAFB",
          "textSecondary": "#D1D5DB",
          "accent": "#FB923C"
        }
      }
    }
  },
  "Sync": {
    "RequireOperationSignatures": true,
    "MaxBatchSize": 100,
    "MaxServerEventsPerSync": 250,
    "MaxProcessingRetries": 5,
    "DefaultQuestionBundleSize": 100,
    "EnableDeadLetterRedriveWorker": true,
    "DeadLetterRedriveIntervalSeconds": 60,
    "DeadLetterRedriveBatchSize": 20,
    "MaxDeadLetterRedriveAttempts": 10
  }
}
